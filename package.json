{
  "name": "yspcollective",
  "version": "1.0.0",
  "description": "YSP Collective website",
  "scripts": {
    "build": "eleventy --config=eleventy.config.js",
    "start": "eleventy --serve --config=eleventy.config.js",
    "dev": "eleventy --serve --watch --config=eleventy.config.js",
    "build:worker-products": "node scripts/build-worker-products.js",
    "deploy:api": "node scripts/build-worker-products.js && wrangler deploy --config wrangler-api.toml --keep-vars"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1"
  }
}
