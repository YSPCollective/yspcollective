        </div>
      </div>

      <!-- Favourites Panel -->
      <div class="acc-panel" id="panel-favourites">
        <p class="acc-section-label">Saved items</p>
        <div id="favs-grid-wrap"></div>
      </div>

      <!-- Profile Panel -->
      <div class="acc-panel" id="panel-profile">
        <p class="acc-section-label">Account details</p>
        <div class="acc-profile-grid">
          <div class="acc-profile-card">
            <h3>Personal Details</h3>
            <div class="acc-profile-row">
              <span>Name</span>
              <span id="prf-name">—</span>
            </div>
            <div class="acc-profile-row">
              <span>Email</span>
              <span id="prf-email">—</span>
            </div>
            <div class="acc-profile-row">
              <span>Member since</span>
              <span id="prf-since">—</span>
            </div>
          </div>
          <div class="acc-profile-card">
            <h3>Preferences</h3>
            <div id="prf-interests-wrap">
              <div class="acc-profile-row">
                <span>Interests</span>
                <span id="prf-interests">—</span>
              </div>
            </div>
            <div id="prf-frag-wrap"></div>
            <div id="prf-beauty-wrap"></div>
          </div>
          <div class="acc-profile-card">
            <h3>Email Preferences</h3>
            <div class="acc-profile-row" style="align-items:center;">
              <span style="line-height:1.4">Offers &amp; recommendations<br><span style="font-size:0.78rem;color:var(--grey-light)">New arrivals, personal picks, exclusive discounts</span></span>
              <label class="acc-email-toggle" id="email-toggle-wrap" title="Toggle marketing emails">
                <input type="checkbox" id="email-marketing-toggle">
                <span class="acc-toggle-track"></span>
              </label>
            </div>
            <p class="acc-email-pref-note" id="email-pref-note"></p>
          </div>
        </div>
        <div class="acc-profile-actions">
          <button class="acc-btn-outline" id="edit-prefs-btn">Update preferences</button>
        </div>
      </div>

      <!-- Orders Panel -->
      <div class="acc-panel" id="panel-orders">
        <p class="acc-section-label">Order history</p>
        <div id="orders-wrap">
          <div class="acc-orders-empty">
            <div class="acc-empty-icon">📦</div>
            <h3 style="font-family:var(--serif);font-size:1.2rem;font-weight:300;margin-bottom:0.5rem">No orders yet</h3>
            <p style="font-size:0.85rem;color:var(--grey);margin-bottom:1.5rem">Your order history will appear here.</p>
            <a href="/fragrances/all.html" style="display:inline-block;padding:0.65rem 1.5rem;background:var(--accent);color:var(--white);text-decoration:none;font-size:0.72rem;letter-spacing:0.12em;text-transform:uppercase;">Shop Now</a>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script src="/ysp-account.js"></script>
  <script>
    const PROXY = 'https://ysp-ai-proxy.rapid-shadow-439d.workers.dev';
    let currentUser = null;
    let chatMessages = [];

    // ── Boot ──────────────────────────────────────────────────────────────────
    async function boot() {
      // Use cached user first to avoid redirect flash
      const cachedUser = YSPAccount.getUser();
      const token = YSPAccount.getToken();

      if (!token) {
        // Definitely not logged in
        sessionStorage.setItem('ysp_redirect_account', '1');
        window.location.href = '/';
        return;
      }

      // Show page immediately with cached data while we verify
      if (cachedUser) {
        currentUser = cachedUser;
        renderAccount(cachedUser);
        document.getElementById('account-loading').style.display = 'none';
        document.getElementById('account-app').classList.add('ready');
        await Promise.all([loadFavourites(), loadRecommendations(cachedUser), loadFullProfile(cachedUser)]);
      }

      // Verify session in background — redirect if invalid
      const verified = await YSPAccount.verifySession();
      if (!verified) {
        sessionStorage.setItem('ysp_redirect_account', '1');
        window.location.href = '/';
        return;
      }

      // If not already rendered (no cache), render now
      if (!cachedUser) {
        currentUser = verified;
        renderAccount(verified);
        await Promise.all([loadFavourites(), loadRecommendations(verified), loadFullProfile(verified)]);
        document.getElementById('account-loading').style.display = 'none';
        document.getElementById('account-app').classList.add('ready');
      }
    }

    function renderAccount(user) {
      document.getElementById('acc-user-name').textContent = `${user.firstName} ${user.lastName}`.trim();
      document.getElementById('acc-user-email').textContent = user.email;
      document.getElementById('prf-name').textContent = `${user.firstName} ${user.lastName}`.trim();
      document.getElementById('prf-email').textContent = user.email;

      // Member since — format createdAt
      const sinceEl = document.getElementById('prf-since');
      if (user.createdAt) {
        try {
          const d = new Date(user.createdAt);
          sinceEl.textContent = d.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
        } catch(_) { sinceEl.textContent = '—'; }
      } else {
        sinceEl.textContent = '—';
      }

      // Profile status
      const statusEl = document.getElementById('acc-profile-status');
      const statusText = document.getElementById('acc-profile-status-text');
      if (!user.profileComplete) {
        statusEl.classList.add('incomplete');
        statusText.innerHTML = 'Profile incomplete — <button onclick="YSPAccount.showProfileQA(currentUser)">complete now</button>';
      }

      // Profile panel
      if (user.profileComplete) {
        document.getElementById('prf-interests').textContent = user.interests || '—';
        renderPrefDetails(user);
      }
    }

    function renderPrefDetails(user) {
      const fragWrap = document.getElementById('prf-frag-wrap');
      const beautyWrap = document.getElementById('prf-beauty-wrap');

      if (user.fragrancePrefs) {
        const fp = user.fragrancePrefs;
        fragWrap.innerHTML = `
          <div style="margin-top:0.8rem;padding-top:0.8rem;border-top:1px solid var(--sand)">
            <p style="font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--accent);margin-bottom:0.6rem">Fragrance</p>
            ${fp.scents?.length ? `<div class="acc-pref-tags">${fp.scents.map(s => `<span class="acc-pref-tag">${s}</span>`).join('')}</div>` : ''}
            ${fp.gender ? `<p style="font-size:0.82rem;color:var(--grey);margin-top:0.4rem">Preference: ${fp.gender}</p>` : ''}
            ${fp.budget ? `<p style="font-size:0.82rem;color:var(--grey)">Budget: ${fp.budget}</p>` : ''}
          </div>
        `;
      }

      if (user.beautyPrefs) {
        const bp = user.beautyPrefs;
        beautyWrap.innerHTML = `
          <div style="margin-top:0.8rem;padding-top:0.8rem;border-top:1px solid var(--sand)">
            <p style="font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--accent);margin-bottom:0.6rem">Beauty</p>
            ${bp.skinType?.length ? `<div class="acc-pref-tags">${bp.skinType.map(s => `<span class="acc-pref-tag">${s}</span>`).join('')}</div>` : ''}
            ${bp.concerns?.length ? `<div class="acc-pref-tags" style="margin-top:0.3rem">${bp.concerns.map(s => `<span class="acc-pref-tag">${s}</span>`).join('')}</div>` : ''}
            ${bp.budget ? `<p style="font-size:0.82rem;color:var(--grey);margin-top:0.4rem">Budget: ${bp.budget}</p>` : ''}
          </div>
        `;
      }
    }

    // ── Recommendations ───────────────────────────────────────────────────────
    // Product catalogue for card rendering (matches worker)
    const PRODUCT_CATALOGUE = {{ collections.allProducts | jsonify | safe }};

    async function loadRecommendations(user) {
      if (!user.profileComplete) {
        document.getElementById('recs-no-profile').style.display = 'block';
        document.getElementById('recs-chat-area').style.display = 'none';
        return;
      }

      const interests = user.interests || 'both';
      const showFrag = interests === 'fragrance' || interests === 'both';
      const showBeauty = interests === 'beauty' || interests === 'both';

      // Hide tabs if only one interest
      const subtabs = document.getElementById('recs-subtabs');
      if (!showFrag || !showBeauty) subtabs.style.display = 'none';
      if (!showFrag) {
        document.getElementById('subtab-fragrance').style.display = 'none';
        document.getElementById('recs-fragrance').classList.remove('active');
        document.getElementById('recs-beauty').classList.add('active');
        document.getElementById('subtab-beauty').classList.add('active');
      }
      if (!showBeauty) {
        document.getElementById('subtab-beauty').style.display = 'none';
      }

      // Load both in parallel
      const tasks = [];
      if (showFrag) tasks.push(loadFragranceRecs(user));
      if (showBeauty) tasks.push(loadBeautyRecs(user));
      await Promise.all(tasks);
    }

    function stripMarkdown(text) {
      return text
        .replace(/\*\*([^*]+)\*\*/g, '$1')
        .replace(/\*([^*]+)\*/g, '$1')
        .replace(/#+\s/g, '')
        .trim();
    }

    /**
     * Render the AI intro text with paragraph formatting.
     * Splits on double newlines or ". " boundaries if the AI returns a wall of text.
     */
    /**
     * Normalise smart/curly quotes and apostrophes to their plain ASCII equivalents.
     * Needed because the AI often returns "Bade'e" (right single quote U+2019)
     * while catalogue data uses a straight apostrophe "Bade'e".
     */
    function normaliseQuotes(str) {
      return str
        .replace(/[\u2018\u2019\u02BC\u02B9\uFF07]/g, "'")  // curly/modifier apostrophes → '
        .replace(/[\u201C\u201D\u00AB\u00BB]/g, '"')         // curly double quotes → "
        .replace(/\u2013|\u2014/g, '-');                      // en/em dash → hyphen
    }

    /**
     * Bold any catalogue product names found in text, then render as paragraphs.
     */
    function renderIntroText(el, text, catalogueProducts) {
      // Normalise quotes in the reply before any processing
      let clean = normaliseQuotes(text)
        .replace(/\*\*([^*]+)\*\*/g, '$1')
        .replace(/\*([^*]+)\*/g, '$1')
        .replace(/#+\s/g, '')
        .trim();

      // Bold catalogue product names wherever they appear
      if (catalogueProducts && catalogueProducts.length) {
        // Sort longest names first so longer names match before shorter subsets
        const sorted = [...catalogueProducts].sort((a, b) => b.name.length - a.name.length);
        sorted.forEach(p => {
          const normName = normaliseQuotes(p.name);
          const escaped = normName.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
          // Case-insensitive match
          const re = new RegExp(`(${escaped})`, 'gi');
          clean = clean.replace(re, '<strong>$1</strong>');
        });
      }

      // Split into paragraphs — honour \n\n first
      let paras = clean.split(/\n\n+/).map(s => s.replace(/\n/g, ' ').trim()).filter(Boolean);

      // If single blob, split at ". [Capital]" boundaries
      if (paras.length === 1 && clean.replace(/<[^>]+>/g, '').length > 200) {
        const parts = clean.split(/(?<=\.)\s+(?=[A-Z])/).map(s => s.trim()).filter(Boolean);
        const merged = [];
        for (let i = 0; i < parts.length; i += 2) {
          merged.push([parts[i], parts[i+1]].filter(Boolean).join(' '));
        }
        paras = merged.length > 1 ? merged : paras;
      }

      el.innerHTML = paras.map(p => `<p>${p}</p>`).join('');
    }

    /**
     * Extract the 1–2 products the AI specifically recommended.
     * Uses exact substring matching (longest name first) with quote normalisation
     * to handle curly apostrophes like "Bade'e" vs "Bade'e".
     */
    function extractMentionedProducts(replyText, catalogueProducts) {
      // Normalise both the reply and product names before comparison
      const normReply = normaliseQuotes(replyText).toLowerCase();

      // Sort longest name first — prevents shorter names matching inside longer ones
      const sorted = [...catalogueProducts].sort((a, b) => b.name.length - a.name.length);

      const matched = [];
      const usedSpans = [];

      sorted.forEach(p => {
        const normName = normaliseQuotes(p.name).toLowerCase();
        const idx = normReply.indexOf(normName);
        if (idx === -1) return;

        // Skip if this span is already consumed by a longer match
        const overlaps = usedSpans.some(s => idx < s.end && (idx + normName.length) > s.start);
        if (!overlaps) {
          matched.push({ product: p, idx });
          usedSpans.push({ start: idx, end: idx + normName.length });
        }
      });

      // Return in order of appearance, capped at 2
      return matched
        .sort((a, b) => a.idx - b.idx)
        .map(m => m.product)
        .slice(0, 2);
    }

    async function loadFragranceRecs(user) {
      const fp = user.fragrancePrefs || {};
      const fragranceProducts = PRODUCT_CATALOGUE.filter(p => p.type === 'fragrance');
      const catalogueNames = fragranceProducts.map(p => `${p.name} (€${p.price})`).join(', ');

      const prompt = `You are recommending fragrances to ${user.firstName} from the YSP Collective range. ` +
        `Their profile — scent preferences: ${(fp.scents||[]).join(', ') || 'no preference'}; ` +
        `occasions: ${(fp.occasions||[]).join(', ') || 'everyday'}; ` +
        `gender preference: ${fp.gender || 'any'}; budget: ${fp.budget || 'flexible'}. ` +
        `Write exactly 2 short paragraphs. First paragraph: one top pick and why it suits them personally. ` +
        `Second paragraph: one alternative for a different occasion or mood. ` +
        `Recommend exactly 2 different products total. ` +
        `Only recommend products from this list: ${catalogueNames}. ` +
        `Use the exact product names as they appear in the list. Do not use markdown bullets, headers, or asterisks.`;

      const reply = await callAI([{ role: 'user', content: prompt }]);
      const introEl = document.getElementById('recs-frag-intro');
      renderIntroText(introEl, reply, fragranceProducts);

      // Match exactly what the AI mentioned (strict, capped at 2)
      let toShow = extractMentionedProducts(reply, fragranceProducts);

      if (toShow.length < 2) {
        // Fallback: accord scoring for any missing slots, no dupes
        const scents = fp.scents || [];
        const mentionedSlugs = new Set(toShow.map(p => p.slug));
        const scored = fragranceProducts
          .filter(p => !mentionedSlugs.has(p.slug))
          .map(p => {
            const accords = p.accords || [];
            const score = accords.filter(a =>
              scents.some(s => a.toLowerCase().includes(s.replace('-',' ').split(' ')[0]))
            ).length;
            return { ...p, score };
          })
          .sort((a, b) => b.score - a.score);
        toShow = [...toShow, ...scored].slice(0, 2);
      }

      renderProductCards('recs-frag-grid', toShow);
    }

    async function loadBeautyRecs(user) {
      const bp = user.beautyPrefs || {};
      const beautyProducts = PRODUCT_CATALOGUE.filter(p => p.type === 'beauty');
      const catalogueNames = beautyProducts.map(p => `${p.name} (€${p.price})`).join(', ');

      const prompt = `You are recommending skincare to ${user.firstName} from the YSP Collective range. ` +
        `Their profile — skin type: ${(bp.skinType||[]).join(', ') || 'normal'}; ` +
        `concerns: ${(bp.concerns||[]).join(', ') || 'general care'}; budget: ${bp.budget || 'flexible'}. ` +
        `Write exactly 2 short paragraphs. First paragraph: one top pick and why it suits their skin. ` +
        `Second paragraph: one complementary product. ` +
        `Recommend exactly 2 different products total. ` +
        `Only recommend products from this list: ${catalogueNames}. ` +
        `Use the exact product names as they appear in the list. Do not use markdown bullets, headers, or asterisks.`;

      const reply = await callAI([{ role: 'user', content: prompt }]);
      const introEl = document.getElementById('recs-beauty-intro');
      renderIntroText(introEl, reply, beautyProducts);

      let toShow = extractMentionedProducts(reply, beautyProducts);

      if (toShow.length < 2) {
        const mentionedSlugs = new Set(toShow.map(p => p.slug));
        const fill = beautyProducts.filter(p => !mentionedSlugs.has(p.slug));
        toShow = [...toShow, ...fill].slice(0, 2);
      }

      renderProductCards('recs-beauty-grid', toShow);
    }

    function renderProductCards(gridId, products) {
      const grid = document.getElementById(gridId);
      grid.innerHTML = '';
      products.slice(0, 4).forEach(p => {
        const image = p.image_main || p.image || '';
        const price = p.price ? (String(p.price).startsWith('€') ? p.price : '€' + p.price) : '';
        const url = p.url || ('/products/' + p.slug + '.html');
        const card = document.createElement('a');
        card.className = 'recs-product-card';
        card.href = url;
        card.style.cssText = 'display:flex;flex-direction:column;height:100%;';
        card.innerHTML = `
          <div class="recs-product-img" style="width:100%;aspect-ratio:1/1;overflow:hidden;flex-shrink:0;">
            ${image
              ? `<img src="${image}" alt="${p.name}" loading="lazy" style="width:100%;height:100%;object-fit:contain;padding:0.8rem;"
                  onerror="this.style.display='none'">`
              : ''
            }
          </div>
          <div style="padding:0.7rem 0.8rem 0.5rem;border-top:1px solid #e6dfd4;flex:1;">
            <span style="display:block;font-size:0.58rem;letter-spacing:0.22em;text-transform:uppercase;color:#9c7b56;margin-bottom:0.3rem;">${p.brand || ''}</span>
            <span style="display:block;font-size:0.82rem;font-weight:400;line-height:1.3;color:#1a1916;margin-bottom:0.25rem;">${p.name}</span>
            <span style="display:block;font-size:0.8rem;color:#8a847a;">${price}</span>
          </div>
          <span class="recs-product-cta" style="display:block;width:100%;padding:0.65rem;border:none;border-top:1px solid #e6dfd4;background:none;cursor:pointer;font-family:inherit;font-size:0.65rem;letter-spacing:0.12em;text-transform:uppercase;color:#8a847a;text-align:center;text-decoration:none;">View Product →</span>
        `;
        grid.appendChild(card);
      });
    }

    function buildPersonalisedIntro(user) {
      const fp = user.fragrancePrefs;
      const bp = user.beautyPrefs;
      const name = user.firstName;
      if (user.interests === 'fragrance' && fp) {
        return `Hi, I'm ${name}. I like ${fp.scents?.join(', ')} scents, wear fragrance for ${fp.occasions?.join(', ')}, prefer ${fp.gender}, budget ${fp.budget}. What do you recommend?`;
      }
      if (user.interests === 'beauty' && bp) {
        return `Hi, I'm ${name}. I have ${bp.skinType?.join(', ')} skin, concerns: ${bp.concerns?.join(', ')}, budget ${bp.budget}. What skincare do you recommend?`;
      }
      return `Hi, I'm ${name}. I'm interested in both fragrance and beauty. What do you recommend based on my profile?`;
    }

    async function callAI(messages) {
      try {
        const token = YSPAccount.getToken();
        const headers = { 'Content-Type': 'application/json' };
        if (token) headers['Authorization'] = `Bearer ${token}`;
        const res = await fetch(PROXY + '/chat', {
          method: 'POST',
          headers,
          body: JSON.stringify({ messages })
        });
        const data = await res.json();
        return data.content || 'Sorry, I couldn\'t get a response. Please try again.';
      } catch (_) {
        return 'Something went wrong. Please try again.';
      }
    }

    function renderAccBotHtml(text) {
      let html = text
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        .replace(/\*([^*]+)\*/g, '<em>$1</em>');

      const lines = html.split('\n');
      const out = [];
      let inItem = false;
      lines.forEach(line => {
        const stripped = line.trim();
        if (/^[-•\d+\.]\s/.test(stripped)) {
          if (!inItem) { out.push('<span class="acc-rec-item">'); inItem = true; }
          else { out.push('</span><span class="acc-rec-item">'); }
          out.push(`<span class="acc-rec-item-name">${stripped.replace(/^[-•\d+\.]\s/, '')}</span>`);
        } else {
          if (inItem) { out.push('</span>'); inItem = false; }
          if (stripped) out.push(`<p style="margin:0 0 0.3rem">${stripped}</p>`);
        }
      });
      if (inItem) out.push('</span>');
      return out.join('');
    }

    function addAIMessage(role, text) {
      const el = document.createElement('div');
      el.className = `acc-ai-msg ${role}`;
      if (role === 'assistant') {
        el.innerHTML = renderAccBotHtml(text);
      } else {
        el.textContent = text;
      }
      document.getElementById('acc-ai-messages').appendChild(el);
      el.scrollIntoView({ behavior: 'smooth', block: 'end' });
    }

    const ACC_CHIPS = [
      'Best fragrance for evenings',
      'Recommend a K-beauty SPF',
      'What pairs with Lattafa Yara?',
      'Best gift under €35',
      'Long-lasting fragrances',
    ];

    function renderAccChips() {
      const el = document.getElementById('acc-ai-chips');
      if (!el) return;
      el.innerHTML = '';
      ACC_CHIPS.forEach(label => {
        const btn = document.createElement('button');
        btn.className = 'acc-ai-chip';
        btn.textContent = label;
        btn.addEventListener('click', () => {
          el.style.display = 'none';
          sendChatMessage(label);
        });
        el.appendChild(btn);
      });
    }

    // Chat input
    async function sendChatMessage(forcedText) {
      const input = document.getElementById('acc-ai-input');
      const msg = forcedText || input.value.trim();
      if (!msg) return;
      if (!forcedText) input.value = '';

      // Hide chips after first use
      const chipsEl = document.getElementById('acc-ai-chips');
      if (chipsEl) chipsEl.style.display = 'none';

      addAIMessage('user', msg);
      chatMessages.push({ role: 'user', content: msg });

      const typingEl = document.getElementById('acc-ai-typing');
      if (typingEl) { typingEl.classList.add('visible'); typingEl.scrollIntoView({ behavior: 'smooth', block: 'end' }); }
      document.getElementById('acc-ai-send').disabled = true;

      const response = await callAI(chatMessages);
      chatMessages.push({ role: 'assistant', content: response });

      if (typingEl) typingEl.classList.remove('visible');
      document.getElementById('acc-ai-send').disabled = false;
      addAIMessage('assistant', response);
    }

    document.getElementById('acc-ai-send').addEventListener('click', () => sendChatMessage());
    document.getElementById('acc-ai-input').addEventListener('keydown', e => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendChatMessage(); }
    });

    // Render suggestion chips once panel loads
    renderAccChips();

    // ── Email preferences toggle ──────────────────────────────────────────────
    (function initEmailToggle() {
      const toggle = document.getElementById('email-marketing-toggle');
      const note   = document.getElementById('email-pref-note');
      if (!toggle) return;

      // Read stored preference (default: subscribed)
      let subscribed = true;
      try {
        const stored = localStorage.getItem('ysp_email_pref');
        if (stored !== null) subscribed = stored === '1';
      } catch(_) {}

      toggle.checked = subscribed;

      toggle.addEventListener('change', async () => {
        const isSubscribed = toggle.checked;
        note.textContent = isSubscribed ? 'Saving…' : 'Saving…';

        try {
          localStorage.setItem('ysp_email_pref', isSubscribed ? '1' : '0');
          const user = currentUser;
          if (user && user.email) {
            const lang = window.YSP_LANG ? window.YSP_LANG.get() : 'en';
            await fetch(PROXY + '/subscribe', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                email: user.email,
                lang,
                unsubscribe: !isSubscribed,
              })
            });
          }
          note.textContent = isSubscribed ? '✓ You\'re subscribed to offers and recommendations.' : '✓ Unsubscribed — you won\'t receive marketing emails.';
        } catch(_) {
          note.textContent = 'Something went wrong. Please try again.';
        }

        setTimeout(() => { note.textContent = ''; }, 4000);
      });
    })();

    // ── Full Profile ─────────────────────────────────────────────────────────
    async function loadFullProfile(user) {
      if (!user.profileComplete) return;
      const data = await YSPAccount.getProfile();
      if (data.error) return;
      const enriched = { ...user, ...data };
      document.getElementById('prf-interests').textContent = enriched.interests || '—';
      renderPrefDetails(enriched);
    }

        // ── Favourites ────────────────────────────────────────────────────────────
    async function loadFavourites() {
      const data = await YSPAccount.getFavourites();
      const favs = data.favourites || [];
      const wrap = document.getElementById('favs-grid-wrap');

      // Update badge
      const badge = document.getElementById('fav-count');
      if (favs.length > 0) {
        badge.textContent = favs.length;
        badge.style.display = 'inline-flex';
      }

      if (favs.length === 0) {
        wrap.innerHTML = `
          <div class="acc-empty">
            <div class="acc-empty-icon">🤍</div>
            <h3>No saved items yet</h3>
            <p>Heart any product to save it here for later.</p>
            <a href="/fragrances/all.html">Browse Fragrances</a>
          </div>
        `;
        return;
      }

      const grid = document.createElement('div');
      grid.className = 'acc-favs-grid';
      favs.forEach(fav => {
        const card = document.createElement('div');
        card.className = 'acc-fav-card';
        card.innerHTML = `
          <a href="/products/${fav.slug}.html">
            <div class="acc-fav-img">
              ${fav.image ? `<img src="${fav.image}" alt="${fav.name}" loading="lazy">` : '🧴'}
            </div>
            <div class="acc-fav-info">
              <p class="acc-fav-name">${fav.name}</p>
              <p class="acc-fav-price">${fav.price}</p>
            </div>
          </a>
          <button class="acc-fav-remove" data-slug="${fav.slug}">Remove</button>
        `;
        card.querySelector('.acc-fav-remove').addEventListener('click', async () => {
          await YSPAccount.toggleFavourite({ slug: fav.slug });
          card.remove();
          const remaining = wrap.querySelectorAll('.acc-fav-card').length;
          if (remaining === 0) loadFavourites();
        });
        grid.appendChild(card);
      });
      wrap.innerHTML = '';
      wrap.appendChild(grid);
    }

    // ── Tabs ──────────────────────────────────────────────────────────────────
    document.querySelectorAll('.acc-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.acc-tab, .acc-panel').forEach(el => el.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById(`panel-${tab.dataset.panel}`).classList.add('active');
      });
    });

    // ── Recs sub-tabs ─────────────────────────────────────────────────────────
    document.querySelectorAll('.recs-subtab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.recs-subtab, .recs-section').forEach(el => el.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById('recs-' + tab.dataset.rec).classList.add('active');
      });
    });

    // ── Buttons ───────────────────────────────────────────────────────────────
    document.getElementById('acc-signout').addEventListener('click', () => YSPAccount.logout());
    document.getElementById('start-profile-btn')?.addEventListener('click', () => {
      YSPAccount.showProfileQA(currentUser);
    });
    document.getElementById('edit-prefs-btn')?.addEventListener('click', () => {
      YSPAccount.showProfileQA(currentUser);
    });

    // ── Handle redirect after login ───────────────────────────────────────────
    if (sessionStorage.getItem('ysp_redirect_account')) {
      sessionStorage.removeItem('ysp_redirect_account');
      window.addEventListener('ysp:loggedIn', () => window.location.reload());
    }

    boot();
  </script>
</body>
</html>
