              <div class="acc-ai-messages" id="acc-ai-messages"></div>
              <div class="acc-ai-typing" id="acc-ai-typing"><span></span><span></span><span></span></div>
              <div class="acc-ai-chips" id="acc-ai-chips"></div>
              <div id="acc-ai-thinking" class="acc-ai-thinking"></div>
              <div class="acc-ai-input-row">
                <input type="text" class="acc-ai-input" id="acc-ai-input"
                  placeholder="Ask about a scent, ingredient, occasion…">
                <button class="acc-ai-send" id="acc-ai-send">Send →</button>
