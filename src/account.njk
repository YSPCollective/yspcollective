---
layout: null
permalink: /account.html
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>My Account — YSP Collective</title>
  <meta name="robots" content="noindex">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Outfit:wght@200;300;400;500&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #1a1916;
      --white: #faf8f5;
      --cream: #f3efe8;
      --sand: #e6dfd4;
      --grey: #8a847a;
      --grey-light: #b5afa5;
      --accent: #9c7b56;
      --accent-light: #c8a87a;
      --serif: 'Playfair Display', Georgia, serif;
      --sans: 'Outfit', -apple-system, sans-serif;
    }

    html { scroll-behavior: smooth; }
    body {
      background: var(--white); color: var(--black);
      font-family: var(--sans); font-weight: 300;
      -webkit-font-smoothing: antialiased;
    }

    /* ── LOADING STATE ── */
    #account-loading {
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
      flex-direction: column; gap: 1rem;
    }
    .loading-spinner {
      width: 32px; height: 32px;
      border: 2px solid var(--sand);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── ACCOUNT LAYOUT ── */
    #account-app { display: none; min-height: 100vh; }
    #account-app.ready { display: block; }

    /* ── TOP BAR ── */
    .acc-topbar {
      background: var(--black);
      padding: 1rem 3.5rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    .acc-topbar-logo {
      font-family: var(--serif); font-size: 1.3rem; font-weight: 300;
      color: var(--white); text-decoration: none; letter-spacing: 0.06em;
    }
    .acc-topbar-logo span {
      display: block; font-family: var(--sans); font-size: 0.5rem;
      letter-spacing: 0.35em; text-transform: uppercase;
      color: rgba(255,255,255,0.4); margin-top: -2px;
    }
    .acc-topbar-actions {
      display: flex; align-items: center; gap: 2rem;
    }
    .acc-topbar-actions a {
      font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase;
      color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.2s;
    }
    .acc-topbar-actions a:hover { color: var(--accent-light); }
    .acc-signout-btn {
      background: none; border: 1px solid rgba(255,255,255,0.15); cursor: pointer;
      font-family: var(--sans); font-size: 0.72rem; letter-spacing: 0.12em;
      text-transform: uppercase; color: rgba(255,255,255,0.4);
      padding: 0.4rem 1rem; transition: all 0.2s;
    }
    .acc-signout-btn:hover { border-color: rgba(255,255,255,0.4); color: var(--white); }

    /* ── HERO ── */
    .acc-hero {
      background: var(--cream);
      border-bottom: 1px solid var(--sand);
      padding: 3rem 3.5rem;
    }
    .acc-hero-inner { max-width: 1100px; margin: 0 auto; }
    .acc-greeting {
      font-size: 0.68rem; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 0.6rem;
    }
    .acc-name {
      font-family: var(--serif); font-size: clamp(2rem, 3vw, 2.8rem);
      font-weight: 300; color: var(--black); margin-bottom: 0.4rem;
    }
    .acc-email { font-size: 0.85rem; color: var(--grey); }
    .acc-profile-status {
      margin-top: 1.2rem; display: inline-flex; align-items: center;
      gap: 0.5rem; font-size: 0.8rem;
    }
    .acc-profile-status .dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--accent);
    }
    .acc-profile-status.incomplete .dot { background: var(--sand); border: 1px solid var(--grey-light); }
    .acc-profile-status button {
      background: none; border: none; cursor: pointer;
      font-family: var(--sans); font-size: 0.78rem;
      color: var(--accent); text-decoration: underline; padding: 0;
    }

    /* ── NAV TABS ── */
    .acc-tabs {
      background: var(--white);
      border-bottom: 1px solid var(--sand);
      padding: 0 3.5rem;
      display: flex; gap: 0;
      position: sticky; top: 0; z-index: 100;
    }
    .acc-tab {
      background: none; border: none; border-bottom: 2px solid transparent;
      cursor: pointer; font-family: var(--sans);
      font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--grey); padding: 1.1rem 1.5rem;
      margin-bottom: -1px; transition: all 0.2s;
    }
    .acc-tab:hover { color: var(--black); }
    .acc-tab.active { color: var(--black); border-bottom-color: var(--accent); }
    .acc-tab-badge {
      display: inline-flex; align-items: center; justify-content: center;
      width: 18px; height: 18px; border-radius: 50%;
      background: var(--accent); color: var(--white);
      font-size: 0.6rem; margin-left: 0.4rem;
    }

    /* ── CONTENT ── */
    .acc-content { max-width: 1100px; margin: 0 auto; padding: 3rem 3.5rem; }
    .acc-panel { display: none; }
    .acc-panel.active { display: block; }

    /* ── SECTION HEADS ── */
    .acc-section-label {
      font-size: 0.62rem; letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 2rem;
    }
    .acc-section-title {
      font-family: var(--serif); font-size: 1.5rem; font-weight: 300;
      margin-bottom: 0.5rem;
    }

    /* ── RECOMMENDATIONS ── */
    .acc-recs-intro {
      background: var(--cream); border: 1px solid var(--sand);
      padding: 2rem; margin-bottom: 2rem;
      display: flex; align-items: flex-start; gap: 1.5rem;
    }
    .acc-recs-icon { font-size: 1.8rem; flex-shrink: 0; }
    .acc-recs-intro h3 {
      font-family: var(--serif); font-size: 1.1rem; font-weight: 400;
      margin-bottom: 0.4rem;
    }
    .acc-recs-intro p { font-size: 0.85rem; color: var(--grey); line-height: 1.6; }
    .acc-recs-intro .acc-btn {
      display: inline-block; margin-top: 0.8rem;
      padding: 0.5rem 1.2rem; background: var(--accent);
      color: var(--white); font-size: 0.72rem; letter-spacing: 0.12em;
      text-transform: uppercase; border: none; cursor: pointer;
      font-family: var(--sans); text-decoration: none; transition: background 0.2s;
    }
    .acc-recs-intro .acc-btn:hover { background: var(--black); }
    .acc-ai-chat-box {
      border: 1px solid var(--sand); background: var(--white);
      min-height: 320px; display: flex; flex-direction: column;
    }
    .acc-ai-messages {
      flex: 1; padding: 1.5rem; overflow-y: auto;
      display: flex; flex-direction: column; gap: 1rem;
    }
    .acc-ai-msg {
      max-width: 80%; font-size: 0.88rem; line-height: 1.7;
      padding: 0.8rem 1rem;
    }
    .acc-ai-msg.assistant {
      background: var(--cream); align-self: flex-start;
      border-left: 2px solid var(--accent);
    }
    .acc-ai-msg.user {
      background: var(--black); color: var(--white);
      align-self: flex-end;
    }
    .acc-ai-input-row {
      border-top: 1px solid var(--sand);
      display: flex;
    }
    .acc-ai-input {
      flex: 1; padding: 0.9rem 1.2rem;
      border: none; background: none;
      font-family: var(--sans); font-size: 0.88rem;
      color: var(--black); outline: none;
    }
    .acc-ai-send {
      padding: 0.9rem 1.5rem; background: var(--accent);
      border: none; cursor: pointer; color: var(--white);
      font-family: var(--sans); font-size: 0.72rem;
      letter-spacing: 0.1em; text-transform: uppercase;
      transition: background 0.2s;
    }
    .acc-ai-send:hover { background: var(--black); }
    .acc-ai-thinking {
      padding: 0.8rem 1rem; font-size: 0.82rem;
      color: var(--grey); font-style: italic;
      display: none;
    }

    /* ── FAVOURITES ── */
    .acc-favs-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1.5rem;
    }
    .acc-fav-card {
      border: 1px solid var(--sand); background: var(--white);
      transition: box-shadow 0.2s;
    }
    .acc-fav-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.07); }
    .acc-fav-card a { text-decoration: none; color: inherit; }
    .acc-fav-img {
      width: 100%; aspect-ratio: 1;
      background: var(--cream);
      object-fit: contain; padding: 1rem;
      display: flex; align-items: center; justify-content: center;
      font-size: 2.5rem;
    }
    .acc-fav-img img { width: 100%; height: 100%; object-fit: contain; }
    .acc-fav-info { padding: 0.9rem 1rem; }
    .acc-fav-name { font-size: 0.85rem; font-weight: 400; margin-bottom: 0.2rem; }
    .acc-fav-price { font-size: 0.82rem; color: var(--accent); }
    .acc-fav-remove {
      display: block; width: 100%; padding: 0.6rem;
      border: none; border-top: 1px solid var(--sand);
      background: none; cursor: pointer;
      font-family: var(--sans); font-size: 0.72rem;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--grey); transition: all 0.2s;
    }
    .acc-fav-remove:hover { background: var(--black); color: var(--white); }
    .acc-empty {
      text-align: center; padding: 4rem 2rem;
      color: var(--grey);
    }
    .acc-empty-icon { font-size: 2.5rem; margin-bottom: 1rem; }
    .acc-empty h3 { font-family: var(--serif); font-size: 1.2rem; font-weight: 300; margin-bottom: 0.5rem; color: var(--black); }
    .acc-empty p { font-size: 0.85rem; margin-bottom: 1.5rem; }
    .acc-empty a {
      display: inline-block; padding: 0.65rem 1.5rem;
      background: var(--accent); color: var(--white);
      text-decoration: none; font-size: 0.72rem;
      letter-spacing: 0.12em; text-transform: uppercase;
      transition: background 0.2s;
    }
    .acc-empty a:hover { background: var(--black); }

    /* ── PROFILE ── */
    .acc-profile-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
    .acc-profile-card {
      border: 1px solid var(--sand); padding: 1.8rem;
    }
    .acc-profile-card h3 {
      font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 1.2rem; padding-bottom: 0.8rem;
      border-bottom: 1px solid var(--sand);
    }
    .acc-profile-row {
      display: flex; justify-content: space-between;
      padding: 0.5rem 0; border-bottom: 1px solid rgba(0,0,0,0.04);
      font-size: 0.85rem;
    }
    .acc-profile-row:last-child { border-bottom: none; }
    .acc-profile-row span:first-child { color: var(--grey); }
    .acc-pref-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
    .acc-pref-tag {
      padding: 0.25rem 0.7rem; border: 1px solid var(--sand);
      font-size: 0.75rem; color: var(--grey);
    }
    .acc-profile-actions { margin-top: 2rem; display: flex; gap: 1rem; }
    .acc-btn-outline {
      padding: 0.65rem 1.5rem; border: 1px solid var(--sand);
      background: none; cursor: pointer; font-family: var(--sans);
      font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--grey); transition: all 0.2s;
    }
    .acc-btn-outline:hover { border-color: var(--black); color: var(--black); }

    /* ── ORDERS ── */
    .acc-orders-empty {
      text-align: center; padding: 4rem 2rem; color: var(--grey);
    }
    .acc-order-card {
      border: 1px solid var(--sand); margin-bottom: 1rem;
      padding: 1.5rem;
    }
    .acc-order-header {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 0.8rem;
    }
    .acc-order-id { font-size: 0.78rem; color: var(--grey); }
    .acc-order-status {
      font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase;
      padding: 0.3rem 0.7rem; background: var(--cream);
      color: var(--accent);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .acc-topbar { padding: 1rem 1.5rem; }
      .acc-hero { padding: 2rem 1.5rem; }
      .acc-tabs { padding: 0 0.5rem; overflow-x: auto; }
      .acc-tab { padding: 1rem 0.8rem; white-space: nowrap; }
      .acc-content { padding: 2rem 1.5rem; }
      .acc-profile-grid { grid-template-columns: 1fr; }
      .acc-topbar-actions { gap: 1rem; }
      .acc-topbar-actions a { display: none; }
    }

    /* ── RECS SUB-TABS ── */
    .recs-subtabs {
      display: flex; gap: 0; border-bottom: 1px solid var(--sand);
      margin-bottom: 2rem;
    }
    .recs-subtab {
      background: none; border: none; border-bottom: 2px solid transparent;
      cursor: pointer; font-family: var(--sans);
      font-size: 0.78rem; letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--grey); padding: 0.8rem 1.8rem;
      margin-bottom: -1px; transition: all 0.2s;
    }
    .recs-subtab:hover { color: var(--black); }
    .recs-subtab.active { color: var(--black); border-bottom-color: var(--accent); }

    .recs-section { display: none; }
    .recs-section.active { display: block; }

    /* ── AI INTRO BLOCK ── */
    .recs-ai-intro {
      background: var(--cream); border-left: 2px solid var(--accent);
      padding: 1.2rem 1.5rem; margin-bottom: 2rem;
      font-size: 0.9rem; line-height: 1.8; color: var(--black);
      min-height: 60px;
    }
    .recs-ai-thinking {
      display: flex; gap: 5px; align-items: center; padding: 0.3rem 0;
    }
    .recs-ai-thinking span {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--accent); opacity: 0.4;
      animation: recsPulse 1.2s ease-in-out infinite;
    }
    .recs-ai-thinking span:nth-child(2) { animation-delay: 0.2s; }
    .recs-ai-thinking span:nth-child(3) { animation-delay: 0.4s; }
    @keyframes recsPulse {
      0%, 100% { opacity: 0.4; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.3); }
    }

    /* ── PRODUCT GRID ── */
    .recs-product-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.2rem;
      margin-bottom: 2.5rem;
    }
    .recs-product-card {
      border: 1px solid var(--sand);
      background: var(--white);
      text-decoration: none;
      color: inherit;
      display: flex; flex-direction: column;
      transition: box-shadow 0.2s, transform 0.2s;
    }
    .recs-product-card:hover {
      box-shadow: 0 6px 24px rgba(0,0,0,0.08);
      transform: translateY(-2px);
    }
    .recs-product-img {
  width: 100%;
  aspect-ratio: 1 / 1;
  background: var(--white);
  overflow: hidden;
}
.recs-product-img img {
  width: 100%; height: 100%;
  object-fit: contain;
  padding: 1rem;
  display: block;
  transition: transform 0.3s;
}
.recs-product-card:hover .recs-product-img img { transform: scale(1.04); }
.recs-product-info {
  padding: 0.8rem 0.9rem 0.5rem;
  border-top: 1px solid var(--sand);
}
.recs-product-brand-top {
  display: block;
  font-size: 0.58rem; letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 0.3rem;
}
.recs-product-name {
  display: block;
  font-size: 0.82rem; font-weight: 400; line-height: 1.3;
  color: var(--black); margin-bottom: 0.3rem;
}
.recs-product-price {
  display: block;
  font-size: 0.8rem; color: var(--grey);
}
    .recs-product-cta {
      display: block; width: 100%; padding: 0.55rem;
      border: none; border-top: 1px solid var(--sand);
      background: none; cursor: pointer; font-family: var(--sans);
      font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--grey); text-align: center;
      transition: all 0.2s; text-decoration: none;
    }
    .recs-product-cta:hover { background: var(--accent); color: var(--white); border-color: var(--accent); }

    @media (max-width: 900px) {
      .recs-product-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 480px) {
      .recs-product-grid { grid-template-columns: repeat(2, 1fr); gap: 0.7rem; }
    }

    /* ── CHAT SECTION ── */
    .recs-chat-wrap { margin-top: 1rem; }
    .recs-chat-label {
      font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 1rem;
    }

    @media (max-width: 768px) {
      .recs-product-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>

  <!-- Loading -->
  <div id="account-loading">
    <div class="loading-spinner"></div>
    <p style="font-size:0.82rem;color:var(--grey)">Loading your account…</p>
  </div>

  <!-- Account App -->
  <div id="account-app">

    <!-- Top Bar -->
    <div class="acc-topbar">
      <a href="/" class="acc-topbar-logo">YSP<span>Collective</span></a>
      <div class="acc-topbar-actions">
        <a href="/fragrances/all.html">Fragrances</a>
        <a href="/beauty/all.html">Beauty</a>
        <button class="acc-signout-btn" id="acc-signout">Sign Out</button>
      </div>
    </div>

    <!-- Hero -->
    <div class="acc-hero">
      <div class="acc-hero-inner">
        <p class="acc-greeting">Welcome back</p>
        <h1 class="acc-name" id="acc-user-name">—</h1>
        <p class="acc-email" id="acc-user-email">—</p>
        <div class="acc-profile-status" id="acc-profile-status">
          <span class="dot"></span>
          <span id="acc-profile-status-text">Profile complete</span>
        </div>
      </div>
    </div>

    <!-- Tabs -->
    <div class="acc-tabs">
      <button class="acc-tab active" data-panel="recommendations">Recommendations</button>
      <button class="acc-tab" data-panel="favourites">Saved Items <span class="acc-tab-badge" id="fav-count" style="display:none"></span></button>
      <button class="acc-tab" data-panel="profile">My Profile</button>
      <button class="acc-tab" data-panel="orders">Orders</button>
    </div>

    <!-- Content -->
    <div class="acc-content">

      <!-- Recommendations Panel -->
      <div class="acc-panel active" id="panel-recommendations">

        <!-- No profile state -->
        <div id="recs-no-profile" style="display:none">
          <div class="acc-recs-intro">
            <div class="acc-recs-icon">✦</div>
            <div>
              <h3>Let's find what you'll love</h3>
              <p>Answer a few quick questions and our advisor will recommend products matched to your taste, skin type, and budget.</p>
              <button class="acc-btn" id="start-profile-btn">Set my preferences →</button>
            </div>
          </div>
        </div>

        <!-- Recommendations area -->
        <div id="recs-chat-area">

          <!-- Fragrance / Beauty sub-tabs -->
          <div class="recs-subtabs" id="recs-subtabs">
            <button class="recs-subtab active" data-rec="fragrance" id="subtab-fragrance">Fragrance</button>
            <button class="recs-subtab" data-rec="beauty" id="subtab-beauty">Beauty</button>
          </div>

          <!-- Fragrance recommendations -->
          <div class="recs-section active" id="recs-fragrance">
            <div class="recs-ai-intro" id="recs-frag-intro">
              <div class="recs-ai-thinking"><span></span><span></span><span></span></div>
            </div>
            <div class="recs-product-grid" id="recs-frag-grid"></div>
          </div>

          <!-- Beauty recommendations -->
          <div class="recs-section" id="recs-beauty">
            <div class="recs-ai-intro" id="recs-beauty-intro">
              <div class="recs-ai-thinking"><span></span><span></span><span></span></div>
            </div>
            <div class="recs-product-grid" id="recs-beauty-grid"></div>
          </div>

          <!-- Chat -->
          <div class="recs-chat-wrap">
            <p class="recs-chat-label">Ask our advisor anything</p>
            <div class="acc-ai-chat-box">
              <div class="acc-ai-messages" id="acc-ai-messages"></div>
              <div class="acc-ai-thinking" id="acc-ai-thinking">Thinking…</div>
              <div class="acc-ai-input-row">
                <input type="text" class="acc-ai-input" id="acc-ai-input"
                  placeholder="Ask about a specific scent, ingredient, occasion…">
                <button class="acc-ai-send" id="acc-ai-send">Send</button>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- Favourites Panel -->
      <div class="acc-panel" id="panel-favourites">
        <p class="acc-section-label">Saved items</p>
        <div id="favs-grid-wrap"></div>
      </div>

      <!-- Profile Panel -->
      <div class="acc-panel" id="panel-profile">
        <p class="acc-section-label">Account details</p>
        <div class="acc-profile-grid">
          <div class="acc-profile-card">
            <h3>Personal Details</h3>
            <div class="acc-profile-row">
              <span>Name</span>
              <span id="prf-name">—</span>
            </div>
            <div class="acc-profile-row">
              <span>Email</span>
              <span id="prf-email">—</span>
            </div>
            <div class="acc-profile-row">
              <span>Member since</span>
              <span id="prf-since">—</span>
            </div>
          </div>
          <div class="acc-profile-card">
            <h3>Preferences</h3>
            <div id="prf-interests-wrap">
              <div class="acc-profile-row">
                <span>Interests</span>
                <span id="prf-interests">—</span>
              </div>
            </div>
            <div id="prf-frag-wrap"></div>
            <div id="prf-beauty-wrap"></div>
          </div>
        </div>
        <div class="acc-profile-actions">
          <button class="acc-btn-outline" id="edit-prefs-btn">Update preferences</button>
        </div>
      </div>

      <!-- Orders Panel -->
      <div class="acc-panel" id="panel-orders">
        <p class="acc-section-label">Order history</p>
        <div id="orders-wrap">
          <div class="acc-orders-empty">
            <div class="acc-empty-icon">📦</div>
            <h3 style="font-family:var(--serif);font-size:1.2rem;font-weight:300;margin-bottom:0.5rem">No orders yet</h3>
            <p style="font-size:0.85rem;color:var(--grey);margin-bottom:1.5rem">Your order history will appear here.</p>
            <a href="/fragrances/all.html" style="display:inline-block;padding:0.65rem 1.5rem;background:var(--accent);color:var(--white);text-decoration:none;font-size:0.72rem;letter-spacing:0.12em;text-transform:uppercase;">Shop Now</a>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script src="/ysp-account.js"></script>
  <script>
    const PROXY = 'https://ysp-ai-proxy.rapid-shadow-439d.workers.dev';
    let currentUser = null;
    let chatMessages = [];

    // ── Boot ──────────────────────────────────────────────────────────────────
    async function boot() {
      // Use cached user first to avoid redirect flash
      const cachedUser = YSPAccount.getUser();
      const token = YSPAccount.getToken();

      if (!token) {
        // Definitely not logged in
        sessionStorage.setItem('ysp_redirect_account', '1');
        window.location.href = '/';
        return;
      }

      // Show page immediately with cached data while we verify
      if (cachedUser) {
        currentUser = cachedUser;
        renderAccount(cachedUser);
        document.getElementById('account-loading').style.display = 'none';
        document.getElementById('account-app').classList.add('ready');
        await Promise.all([loadFavourites(), loadRecommendations(cachedUser), loadFullProfile(cachedUser)]);
      }

      // Verify session in background — redirect if invalid
      const verified = await YSPAccount.verifySession();
      if (!verified) {
        sessionStorage.setItem('ysp_redirect_account', '1');
        window.location.href = '/';
        return;
      }

      // If not already rendered (no cache), render now
      if (!cachedUser) {
        currentUser = verified;
        renderAccount(verified);
        await Promise.all([loadFavourites(), loadRecommendations(verified), loadFullProfile(verified)]);
        document.getElementById('account-loading').style.display = 'none';
        document.getElementById('account-app').classList.add('ready');
      }
    }

    function renderAccount(user) {
      document.getElementById('acc-user-name').textContent = `${user.firstName} ${user.lastName}`.trim();
      document.getElementById('acc-user-email').textContent = user.email;
      document.getElementById('prf-name').textContent = `${user.firstName} ${user.lastName}`.trim();
      document.getElementById('prf-email').textContent = user.email;

      // Profile status
      const statusEl = document.getElementById('acc-profile-status');
      const statusText = document.getElementById('acc-profile-status-text');
      if (!user.profileComplete) {
        statusEl.classList.add('incomplete');
        statusText.innerHTML = 'Profile incomplete — <button onclick="YSPAccount.showProfileQA(currentUser)">complete now</button>';
      }

      // Profile panel
      if (user.profileComplete) {
        document.getElementById('prf-interests').textContent = user.interests || '—';
        renderPrefDetails(user);
      }
    }

    function renderPrefDetails(user) {
      const fragWrap = document.getElementById('prf-frag-wrap');
      const beautyWrap = document.getElementById('prf-beauty-wrap');

      if (user.fragrancePrefs) {
        const fp = user.fragrancePrefs;
        fragWrap.innerHTML = `
          <div style="margin-top:0.8rem;padding-top:0.8rem;border-top:1px solid var(--sand)">
            <p style="font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--accent);margin-bottom:0.6rem">Fragrance</p>
            ${fp.scents?.length ? `<div class="acc-pref-tags">${fp.scents.map(s => `<span class="acc-pref-tag">${s}</span>`).join('')}</div>` : ''}
            ${fp.gender ? `<p style="font-size:0.82rem;color:var(--grey);margin-top:0.4rem">Preference: ${fp.gender}</p>` : ''}
            ${fp.budget ? `<p style="font-size:0.82rem;color:var(--grey)">Budget: ${fp.budget}</p>` : ''}
          </div>
        `;
      }

      if (user.beautyPrefs) {
        const bp = user.beautyPrefs;
        beautyWrap.innerHTML = `
          <div style="margin-top:0.8rem;padding-top:0.8rem;border-top:1px solid var(--sand)">
            <p style="font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--accent);margin-bottom:0.6rem">Beauty</p>
            ${bp.skinType?.length ? `<div class="acc-pref-tags">${bp.skinType.map(s => `<span class="acc-pref-tag">${s}</span>`).join('')}</div>` : ''}
            ${bp.concerns?.length ? `<div class="acc-pref-tags" style="margin-top:0.3rem">${bp.concerns.map(s => `<span class="acc-pref-tag">${s}</span>`).join('')}</div>` : ''}
            ${bp.budget ? `<p style="font-size:0.82rem;color:var(--grey);margin-top:0.4rem">Budget: ${bp.budget}</p>` : ''}
          </div>
        `;
      }
    }

    // ── Recommendations ───────────────────────────────────────────────────────
    // Product catalogue for card rendering (matches worker)
    const PRODUCT_CATALOGUE = {{ collections.allProducts | jsonify | safe }};

    async function loadRecommendations(user) {
      if (!user.profileComplete) {
        document.getElementById('recs-no-profile').style.display = 'block';
        document.getElementById('recs-chat-area').style.display = 'none';
        return;
      }

      const interests = user.interests || 'both';
      const showFrag = interests === 'fragrance' || interests === 'both';
      const showBeauty = interests === 'beauty' || interests === 'both';

      // Hide tabs if only one interest
      const subtabs = document.getElementById('recs-subtabs');
      if (!showFrag || !showBeauty) subtabs.style.display = 'none';
      if (!showFrag) {
        document.getElementById('subtab-fragrance').style.display = 'none';
        document.getElementById('recs-fragrance').classList.remove('active');
        document.getElementById('recs-beauty').classList.add('active');
        document.getElementById('subtab-beauty').classList.add('active');
      }
      if (!showBeauty) {
        document.getElementById('subtab-beauty').style.display = 'none';
      }

      // Load both in parallel
      const tasks = [];
      if (showFrag) tasks.push(loadFragranceRecs(user));
      if (showBeauty) tasks.push(loadBeautyRecs(user));
      await Promise.all(tasks);
    }

    function stripMarkdown(text) {
      return text
        .replace(/\*\*([^*]+)\*\*/g, '$1')
        .replace(/\*([^*]+)\*/g, '$1')
        .replace(/#+\s/g, '')
        .trim();
    }

    async function loadFragranceRecs(user) {
      const fp = user.fragrancePrefs || {};
      const prompt = `I need concise fragrance recommendations for ${user.firstName}. Their profile: scent preferences: ${(fp.scents||[]).join(', ')}, occasions: ${(fp.occasions||[]).join(', ')}, gender preference: ${fp.gender || 'any'}, budget: ${fp.budget || 'flexible'}. In 2-3 sentences max, tell them which 2-3 products from your range suit them best and why. Be specific, mention product names and prices.`;
      
      const reply = await callAI([{ role: 'user', content: prompt }]);
      const introEl = document.getElementById('recs-frag-intro');
      introEl.textContent = stripMarkdown(reply);

      // Score fragrance products by accord match against user scent prefs
      const scents = fp.scents || [];
      const products = PRODUCT_CATALOGUE.filter(p => p.type === 'fragrance');
      const scored = products.map(p => {
        const accords = p.accords || [];
        const score = accords.filter(a =>
          scents.some(s => a.toLowerCase().includes(s.replace('-',' ').split(' ')[0]))
        ).length;
        return { ...p, score };
      }).sort((a, b) => b.score - a.score);
      renderProductCards('recs-frag-grid', scored);
    }

    async function loadBeautyRecs(user) {
      const bp = user.beautyPrefs || {};
      const prompt = `I need concise beauty/skincare recommendations for ${user.firstName}. Their profile: skin type: ${(bp.skinType||[]).join(', ')}, concerns: ${(bp.concerns||[]).join(', ')}, budget: ${bp.budget || 'flexible'}. In 2-3 sentences max, tell them which products from your range suit them best and why. Be specific, mention product names and prices.`;
      
      const reply = await callAI([{ role: 'user', content: prompt }]);
      const introEl = document.getElementById('recs-beauty-intro');
      introEl.textContent = stripMarkdown(reply);

      const beautyProducts = PRODUCT_CATALOGUE.filter(p => p.type === 'beauty');
      renderProductCards('recs-beauty-grid', beautyProducts);
    }

    function renderProductCards(gridId, products) {
      const grid = document.getElementById(gridId);
      grid.innerHTML = '';
      products.slice(0, 4).forEach(p => {
        // Support both allProducts format (image_main, price as number) and legacy
        const image = p.image_main || p.image || '';
        const price = p.price ? (String(p.price).startsWith('€') ? p.price : '€' + p.price) : '';
        const url = p.url || ('/products/' + p.slug + '.html');
        const card = document.createElement('a');
        card.className = 'recs-product-card';
        card.href = url;
       card.innerHTML = `
  <div class="recs-product-img">
    ${image ? `<img src="${image}" alt="${p.name}" loading="lazy" onerror="this.style.display='none'">` : ''}
  </div>
  <div class="recs-product-info">
    <span class="recs-product-brand-top">${p.brand || ''}</span>
    <span class="recs-product-name">${p.name}</span>
    <span class="recs-product-price">${price}</span>
  </div>
  <span class="recs-product-cta">View Product →</span>
`;
        grid.appendChild(card);
      });
    }

    function buildPersonalisedIntro(user) {
      const fp = user.fragrancePrefs;
      const bp = user.beautyPrefs;
      const name = user.firstName;
      if (user.interests === 'fragrance' && fp) {
        return `Hi, I'm ${name}. I like ${fp.scents?.join(', ')} scents, wear fragrance for ${fp.occasions?.join(', ')}, prefer ${fp.gender}, budget ${fp.budget}. What do you recommend?`;
      }
      if (user.interests === 'beauty' && bp) {
        return `Hi, I'm ${name}. I have ${bp.skinType?.join(', ')} skin, concerns: ${bp.concerns?.join(', ')}, budget ${bp.budget}. What skincare do you recommend?`;
      }
      return `Hi, I'm ${name}. I'm interested in both fragrance and beauty. What do you recommend based on my profile?`;
    }

    async function callAI(messages) {
      try {
        const token = YSPAccount.getToken();
        const headers = { 'Content-Type': 'application/json' };
        if (token) headers['Authorization'] = `Bearer ${token}`;
        const res = await fetch(PROXY + '/chat', {
          method: 'POST',
          headers,
          body: JSON.stringify({ messages })
        });
        const data = await res.json();
        return data.content || 'Sorry, I couldn\'t get a response. Please try again.';
      } catch (_) {
        return 'Something went wrong. Please try again.';
      }
    }

    function addAIMessage(role, text) {
      const el = document.createElement('div');
      el.className = `acc-ai-msg ${role}`;
      el.textContent = stripMarkdown(text);
      document.getElementById('acc-ai-messages').appendChild(el);
      el.scrollIntoView({ behavior: 'smooth', block: 'end' });
    }

    // Chat input
    async function sendChatMessage() {
      const input = document.getElementById('acc-ai-input');
      const msg = input.value.trim();
      if (!msg) return;
      input.value = '';

      addAIMessage('user', msg);
      chatMessages.push({ role: 'user', content: msg });

      document.getElementById('acc-ai-thinking').style.display = 'block';
      document.getElementById('acc-ai-send').disabled = true;

      const response = await callAI(chatMessages);
      chatMessages.push({ role: 'assistant', content: response });

      document.getElementById('acc-ai-thinking').style.display = 'none';
      document.getElementById('acc-ai-send').disabled = false;
      addAIMessage('assistant', response);
    }

    document.getElementById('acc-ai-send').addEventListener('click', sendChatMessage);
    document.getElementById('acc-ai-input').addEventListener('keydown', e => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendChatMessage(); }
    });

    // ── Full Profile ─────────────────────────────────────────────────────────
    async function loadFullProfile(user) {
      if (!user.profileComplete) return;
      const data = await YSPAccount.getProfile();
      if (data.error) return;
      const enriched = { ...user, ...data };
      document.getElementById('prf-interests').textContent = enriched.interests || '—';
      renderPrefDetails(enriched);
    }

        // ── Favourites ────────────────────────────────────────────────────────────
    async function loadFavourites() {
      const data = await YSPAccount.getFavourites();
      const favs = data.favourites || [];
      const wrap = document.getElementById('favs-grid-wrap');

      // Update badge
      const badge = document.getElementById('fav-count');
      if (favs.length > 0) {
        badge.textContent = favs.length;
        badge.style.display = 'inline-flex';
      }

      if (favs.length === 0) {
        wrap.innerHTML = `
          <div class="acc-empty">
            <div class="acc-empty-icon">🤍</div>
            <h3>No saved items yet</h3>
            <p>Heart any product to save it here for later.</p>
            <a href="/fragrances/all.html">Browse Fragrances</a>
          </div>
        `;
        return;
      }

      const grid = document.createElement('div');
      grid.className = 'acc-favs-grid';
      favs.forEach(fav => {
        const card = document.createElement('div');
        card.className = 'acc-fav-card';
        card.innerHTML = `
          <a href="/products/${fav.slug}.html">
            <div class="acc-fav-img">
              ${fav.image ? `<img src="${fav.image}" alt="${fav.name}" loading="lazy">` : '🧴'}
            </div>
            <div class="acc-fav-info">
              <p class="acc-fav-name">${fav.name}</p>
              <p class="acc-fav-price">${fav.price}</p>
            </div>
          </a>
          <button class="acc-fav-remove" data-slug="${fav.slug}">Remove</button>
        `;
        card.querySelector('.acc-fav-remove').addEventListener('click', async () => {
          await YSPAccount.toggleFavourite({ slug: fav.slug });
          card.remove();
          const remaining = wrap.querySelectorAll('.acc-fav-card').length;
          if (remaining === 0) loadFavourites();
        });
        grid.appendChild(card);
      });
      wrap.innerHTML = '';
      wrap.appendChild(grid);
    }

    // ── Tabs ──────────────────────────────────────────────────────────────────
    document.querySelectorAll('.acc-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.acc-tab, .acc-panel').forEach(el => el.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById(`panel-${tab.dataset.panel}`).classList.add('active');
      });
    });

    // ── Recs sub-tabs ─────────────────────────────────────────────────────────
    document.querySelectorAll('.recs-subtab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.recs-subtab, .recs-section').forEach(el => el.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById('recs-' + tab.dataset.rec).classList.add('active');
      });
    });

    // ── Buttons ───────────────────────────────────────────────────────────────
    document.getElementById('acc-signout').addEventListener('click', () => YSPAccount.logout());
    document.getElementById('start-profile-btn')?.addEventListener('click', () => {
      YSPAccount.showProfileQA(currentUser);
    });
    document.getElementById('edit-prefs-btn')?.addEventListener('click', () => {
      YSPAccount.showProfileQA(currentUser);
    });

    // ── Handle redirect after login ───────────────────────────────────────────
    if (sessionStorage.getItem('ysp_redirect_account')) {
      sessionStorage.removeItem('ysp_redirect_account');
      window.addEventListener('ysp:loggedIn', () => window.location.reload());
    }

    boot();
  </script>
</body>
</html>
