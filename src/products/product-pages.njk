---
layout: base.njk
pagination:
  data: collections.allProducts
  size: 1
  alias: product
permalink: "products/{{ product.slug }}.html"
---

{% set badgeText = product.custom_badge or product.badge %}
{% set isFragrance = product.concentration %}
{% set allProducts = collections.allProducts %}

{% set schemaData %}
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "{{ product.name }}",
  "image": "https://yspcollective.com{{ product.image_main }}",
  "description": "{{ product.description_short }}",
  "brand": { "@type": "Brand", "name": "{{ product.brand }}" },
  "offers": {
    "@type": "Offer",
    "price": "{{ product.price }}",
    "priceCurrency": "EUR",
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": "YSP Collective" }
  }
}
{% endset %}

{% block head_extra %}
<style>
  .breadcrumb { padding: 7rem 4rem 0; font-size: 0.75rem; letter-spacing: 0.1em; color: var(--grey); }
  .breadcrumb a { color: var(--grey); text-decoration: none; }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb span { margin: 0 0.5rem; }

  .product-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; padding: 2.5rem 4rem 6rem; max-width: 1400px; margin: 0 auto; }

  .gallery-main { aspect-ratio: 1; overflow: hidden; background: var(--cream); position: relative; }
  .gallery-main img { width: 100%; height: 100%; object-fit: cover; transition: opacity 0.3s ease; }
  .gallery-thumbs { display: flex; gap: 0.6rem; margin-top: 0.8rem; flex-wrap: wrap; }
  .gallery-thumb { width: 72px; height: 72px; overflow: hidden; background: var(--cream); cursor: pointer; border: 2px solid transparent; transition: border-color 0.2s; flex-shrink: 0; }
  .gallery-thumb.active { border-color: var(--accent); }
  .gallery-thumb img { width: 100%; height: 100%; object-fit: cover; }

  .product-info { padding-top: 0.5rem; }
  .product-badge-wrap { margin-bottom: 1.2rem; }
  .pdp-badge { display: inline-block; font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--white); background: var(--accent); padding: 0.25rem 0.7rem; }
  .pdp-badge.badge-popular { background: var(--grey); }
  .pdp-badge.badge-curated { background: var(--black); }
  .pdp-badge.badge-new { background: #6a9a6a; }
  .pdp-badge.badge-premium { background: #8b6914; }
  .pdp-badge.badge-limited { background: #8b3a3a; }
  .product-brand { font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.6rem; }
  .product-name { font-family: var(--serif); font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 300; line-height: 1.15; margin-bottom: 0.6rem; }
  .product-meta { font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--grey); margin-bottom: 1.8rem; }
  .product-price-wrap { display: flex; align-items: baseline; gap: 1rem; margin-bottom: 2rem; }
  .product-price { font-family: var(--serif); font-size: 2.4rem; font-weight: 400; color: var(--black); }
  .product-rrp { font-family: var(--serif); font-size: 1.4rem; color: var(--grey-light); text-decoration: line-through; }
  .product-desc { font-size: 0.92rem; line-height: 1.85; color: var(--grey); margin-bottom: 2rem; border-left: 2px solid var(--accent); padding-left: 1.2rem; }

  .quick-specs { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; margin-bottom: 2rem; }
  .spec-item { padding: 0.8rem 1rem; background: var(--cream); }
  .spec-label { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--grey); margin-bottom: 0.2rem; }
  .spec-value { font-size: 0.88rem; color: var(--black); }

  .accords-wrap { margin-bottom: 2rem; }
  .accords-label { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--grey); margin-bottom: 0.6rem; }
  .accords-list { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .accord-tag { padding: 0.3rem 0.8rem; border: 1px solid var(--sand); font-size: 0.75rem; color: var(--grey); letter-spacing: 0.08em; }

  .product-cta { display: flex; gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap; }
  .btn-enquire { padding: 1rem 2.5rem; background: var(--black); color: var(--white); font-family: var(--sans); font-size: 0.78rem; letter-spacing: 0.14em; text-transform: uppercase; text-decoration: none; transition: background 0.2s, transform 0.2s; cursor: pointer; border: none; display: inline-block; }
  .btn-enquire:hover { background: var(--accent); transform: translateY(-1px); }
  .btn-shop { padding: 1rem 2rem; border: 1px solid var(--sand); color: var(--black); font-family: var(--sans); font-size: 0.78rem; letter-spacing: 0.14em; text-transform: uppercase; text-decoration: none; transition: all 0.2s; display: inline-flex; align-items: center; gap: 0.5rem; }
  .btn-shop:hover { border-color: var(--accent); color: var(--accent); }

  .trust-badges { display: flex; gap: 1.5rem; flex-wrap: wrap; padding: 1.2rem 0; border-top: 1px solid var(--sand); border-bottom: 1px solid var(--sand); margin-bottom: 2rem; }
  .trust-badge { font-size: 0.72rem; color: var(--grey); display: flex; align-items: center; gap: 0.4rem; }
  .trust-badge-icon { color: var(--accent); }

  .tabs-wrap { padding: 0 4rem 5rem; max-width: 1400px; margin: 0 auto; }
  .tab-nav { display: flex; border-bottom: 1px solid var(--sand); margin-bottom: 2rem; overflow-x: auto; }
  .tab-btn { padding: 0.8rem 1.5rem; font-family: var(--sans); font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--grey); background: none; border: none; border-bottom: 2px solid transparent; cursor: pointer; white-space: nowrap; transition: all 0.2s; }
  .tab-btn.active { color: var(--black); border-bottom-color: var(--accent); }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }
  .tab-panel p { font-size: 0.9rem; line-height: 1.85; color: var(--grey); margin-bottom: 1rem; }
  .details-table { width: 100%; border-collapse: collapse; }
  .details-table tr { border-bottom: 1px solid var(--sand); }
  .details-table td { padding: 0.7rem 0; font-size: 0.88rem; vertical-align: top; }
  .details-table td:first-child { color: var(--grey); width: 42%; font-size: 0.78rem; letter-spacing: 0.06em; padding-right: 1rem; }
  .ysp-thoughts { background: var(--cream); padding: 2rem; border-left: 3px solid var(--accent); }
  .ysp-thoughts-label { font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.8rem; }
  .ysp-thoughts p { font-size: 0.9rem; line-height: 1.85; color: var(--grey); margin-bottom: 0.8rem; }

  .related-section { padding: 5rem 4rem; border-top: 1px solid var(--sand); background: var(--cream); }
  .related-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-top: 2rem; }
  .related-card { background: var(--white); border: 1px solid var(--sand); text-decoration: none; color: inherit; transition: border-color 0.3s, transform 0.3s; display: block; }
  .related-card:hover { border-color: var(--accent); transform: translateY(-3px); }
  .related-card-img { aspect-ratio: 1; overflow: hidden; background: var(--cream); }
  .related-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
  .related-card:hover .related-card-img img { transform: scale(1.04); }
  .related-card-body { padding: 1.2rem; }
  .related-card-badge { font-size: 0.6rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--white); background: var(--accent); padding: 0.2rem 0.5rem; display: inline-block; margin-bottom: 0.5rem; }
  .related-card-name { font-family: var(--serif); font-size: 1.1rem; font-weight: 300; margin-bottom: 0.3rem; line-height: 1.3; }
  .related-card-meta { font-size: 0.72rem; color: var(--grey); margin-bottom: 0.6rem; }
  .related-card-price { font-family: var(--serif); font-size: 1.3rem; color: var(--black); }

  @media (max-width: 900px) {
    .breadcrumb { padding: 6rem 1.5rem 0; }
    .product-wrap { grid-template-columns: 1fr; gap: 2rem; padding: 2rem 1.5rem 4rem; }
    .quick-specs { grid-template-columns: 1fr; }
    .related-section { padding: 3rem 1.5rem; }
    .related-grid { grid-template-columns: 1fr 1fr; }
    .tabs-wrap { padding: 0 1.5rem 3rem; }
  }
  @media (max-width: 500px) { .related-grid { grid-template-columns: 1fr; } }
</style>
{% endblock %}

<div class="breadcrumb">
  <a href="/">Home</a><span>›</span>
  <a href="/#{{ 'featured-fragrances' if isFragrance else 'featured-beauty' }}">{{ 'Fragrance' if isFragrance else 'Skincare' }}</a><span>›</span>
  <span>{{ product.name }}</span>
</div>

<div class="product-wrap">
  <div class="gallery-col">
    <div class="gallery-main">
      <img id="main-img" src="{{ product.image_main }}" alt="{{ product.name }}" />
    </div>
    <div class="gallery-thumbs" id="gallery-thumbs">
      {% for img in product.gallery %}
      <div class="gallery-thumb {% if loop.first %}active{% endif %}" data-src="{{ img }}">
        <img src="{{ img }}" alt="{{ product.name }} {{ loop.index }}" loading="lazy">
      </div>
      {% endfor %}
    </div>
  </div>

  <div class="product-info">
    {% if badgeText %}
    <div class="product-badge-wrap">
      <span class="pdp-badge {{ badgeText | badgeClass }}">{{ badgeText }}</span>
    </div>
    {% endif %}
    <div class="product-brand">{{ product.brand }}</div>
    <h1 class="product-name">{{ product.name }}</h1>
    <div class="product-meta">
      {% if isFragrance %}{{ product.gender }} · Fragrance{% else %}{{ product.category }}{% endif %}
    </div>
    <div class="product-price-wrap">
      <div class="product-price">€{{ product.price }}</div>
      {% if product.rrp %}<div class="product-rrp">€{{ product.rrp }}</div>{% endif %}
    </div>
    <div class="product-desc">{{ product.description_short }}</div>

    {% if isFragrance %}
    <div class="quick-specs">
      <div class="spec-item"><div class="spec-label">Concentration</div><div class="spec-value">{{ product.concentration }}</div></div>
      <div class="spec-item"><div class="spec-label">Size</div><div class="spec-value">{{ product.size }}</div></div>
      <div class="spec-item"><div class="spec-label">Longevity</div><div class="spec-value">{{ product.longevity or '—' }}</div></div>
      <div class="spec-item"><div class="spec-label">Projection</div><div class="spec-value">{{ product.projection or '—' }}</div></div>
    </div>
    {% if product.accords %}
    <div class="accords-wrap">
      <div class="accords-label" data-i18n="pdp_accords">Main Accords</div>
      <div class="accords-list">
        {% for accord in product.accords %}<span class="accord-tag">{{ accord }}</span>{% endfor %}
      </div>
    </div>
    {% endif %}
    {% endif %}

    <div class="product-cta">
      <a href="/#contact" class="btn-enquire" id="btn-enquire" data-i18n="pdp_enquire">Enquire About This Product</a>
      {% if product.amazon_url %}
      <a href="{{ product.amazon_url }}" class="btn-shop" target="_blank" rel="noopener" data-i18n="pdp_amazon">📦 Buy on Amazon</a>
      {% endif %}
    </div>

    <div class="trust-badges">
      <div class="trust-badge"><span class="trust-badge-icon">✓</span><span data-i18n="pdp_trust_1">EU Authorised Stock</span></div>
      <div class="trust-badge"><span class="trust-badge-icon">✓</span><span data-i18n="pdp_trust_2">Authentic &amp; Sealed</span></div>
      <div class="trust-badge"><span class="trust-badge-icon">✓</span><span data-i18n="pdp_trust_3">Fast EU Shipping</span></div>
      <div class="trust-badge"><span class="trust-badge-icon">✓</span><span data-i18n="pdp_trust_4">90-Day Guarantee</span></div>
    </div>
  </div>
</div>

<div class="tabs-wrap">
  <div class="tab-nav">
    <button class="tab-btn active" data-tab="description" data-i18n="pdp_tab_desc">Full Description</button>
    <button class="tab-btn" data-tab="details" data-i18n="pdp_tab_details">Details &amp; Specs</button>
    <button class="tab-btn" data-tab="thoughts" data-i18n="pdp_tab_thoughts">YSP Thoughts</button>
    <button class="tab-btn" data-tab="shipping" data-i18n="pdp_tab_shipping">Shipping &amp; Returns</button>
  </div>

  <div class="tab-panel active" id="tab-description">
    {{ product.description_full | safe }}
  </div>

  <div class="tab-panel" id="tab-details">
    <table class="details-table">
      {% set details = product | detailsJson %}
      {% set detailRows = details | safe %}
      <tbody id="details-tbody"></tbody>
    </table>
  </div>

  <div class="tab-panel" id="tab-thoughts">
    <div class="ysp-thoughts">
      <div class="ysp-thoughts-label" data-i18n="pdp_thoughts_label">Why We Carry This</div>
      {{ product.ysp_thoughts | safe }}
    </div>
  </div>

  <div class="tab-panel" id="tab-shipping">
    <p data-i18n="pdp_shipping_p1">We ship across Europe from our base in Portugal. Most orders dispatch within 24 hours. Delivery is typically 2–5 business days depending on destination. No hidden import costs within the EU.</p>
    <p data-i18n="pdp_shipping_p2">All products are new, sealed, and sourced from authorised EU distributors. If there's any issue with your order, contact us within 14 days and we'll arrange a return or replacement promptly.</p>
    <p>For questions before or after purchase, email <a href="mailto:info@yspcollective.com" style="color:var(--accent)">info@yspcollective.com</a> — we respond within 24 hours Monday to Friday.</p>
  </div>
</div>

{% set related = collections.allProducts | relatedProducts(product.slug, product.type, product.accords) %}
{% if related.length %}
<section class="related-section">
  <p class="section-label" data-i18n="pdp_related_label">You May Also Like</p>
  <h2 class="section-title" data-i18n="pdp_related_title">Similar products</h2>
  <div class="related-grid">
    {% for p in related %}
    <a href="/products/{{ p.slug }}.html" class="related-card">
      <div class="related-card-img">
        <img src="{{ p.image_main }}" alt="{{ p.name }}" loading="lazy">
      </div>
      <div class="related-card-body">
        {% set relBadge = p.custom_badge or p.badge %}
        {% if relBadge %}<span class="related-card-badge">{{ relBadge }}</span>{% endif %}
        <div class="related-card-name">{{ p.name }}</div>
        <div class="related-card-meta">{% if p.concentration %}{{ p.gender }} · Fragrance{% else %}{{ p.category }}{% endif %}</div>
        <div class="related-card-price">€{{ p.price }}</div>
      </div>
    </a>
    {% endfor %}
  </div>
</section>
{% endif %}

<script>
  // Gallery
  const mainImg = document.getElementById('main-img');
  document.querySelectorAll('.gallery-thumb').forEach(thumb => {
    thumb.addEventListener('click', () => {
      mainImg.src = thumb.dataset.src;
      document.querySelectorAll('.gallery-thumb').forEach(t => t.classList.remove('active'));
      thumb.classList.add('active');
    });
  });
  document.addEventListener('keydown', e => {
    const thumbs = [...document.querySelectorAll('.gallery-thumb')];
    const idx = thumbs.findIndex(t => t.classList.contains('active'));
    if (e.key === 'ArrowRight' && idx < thumbs.length - 1) thumbs[idx + 1].click();
    if (e.key === 'ArrowLeft' && idx > 0) thumbs[idx - 1].click();
  });

  // Tabs
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
    });
  });

  // Details table
  const detailsData = {{ product | detailsJson | safe }};
  const tbody = document.getElementById('details-tbody');
  if (tbody && detailsData) {
    detailsData.forEach(row => {
      const tr = document.createElement('tr');
      tr.innerHTML = `<td>${row.label}</td><td>${row.value}</td>`;
      tbody.appendChild(tr);
    });
  }

  // Enquire button
  document.getElementById('btn-enquire').addEventListener('click', e => {
    e.preventDefault();
    sessionStorage.setItem('enquiry_subject', 'Product Enquiry — {{ product.name }}');
    window.location.href = '/#contact';
  });
</script>
