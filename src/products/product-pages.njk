        woody:    `<rect x="${s*0.44}" y="${s*0.14}" width="${s*0.12}" height="${s*0.64}" rx="2" fill="${c}" opacity="0.55"/><path d="M${s/2} ${s*0.35} L${s*0.26} ${s*0.56} L${s*0.36} ${s*0.56} L${s*0.36} ${s*0.72} L${s*0.64} ${s*0.72} L${s*0.64} ${s*0.56} L${s*0.74} ${s*0.56} Z" fill="${c}" opacity="0.38"/><path d="M${s/2} ${s*0.24} L${s*0.3} ${s*0.44} L${s*0.4} ${s*0.44} L${s*0.4} ${s*0.58} L${s*0.6} ${s*0.58} L${s*0.6} ${s*0.44} L${s*0.7} ${s*0.44} Z" fill="${c}" opacity="0.5"/><path d="M${s/2} ${s*0.14} L${s*0.35} ${s*0.3} L${s*0.43} ${s*0.3} L${s*0.43} ${s*0.43} L${s*0.57} ${s*0.43} L${s*0.57} ${s*0.3} L${s*0.65} ${s*0.3} Z" fill="${c}" opacity="0.65"/><circle cx="${s/2}" cy="${s*0.13}" r="${s*0.04}" fill="${c}" opacity="0.8"/>`,
        oriental: `<polygon points="${s/2},${s*0.1} ${s*0.58},${s*0.35} ${s*0.84},${s*0.35} ${s*0.63},${s*0.51} ${s*0.71},${s*0.76} ${s/2},${s*0.62} ${s*0.29},${s*0.76} ${s*0.37},${s*0.51} ${s*0.16},${s*0.35} ${s*0.42},${s*0.35}" fill="${c}" opacity="0.18"/><polygon points="${s/2},${s*0.18} ${s*0.56},${s*0.34} ${s*0.74},${s*0.34} ${s*0.6},${s*0.46} ${s*0.65},${s*0.62} ${s/2},${s*0.53} ${s*0.35},${s*0.62} ${s*0.4},${s*0.46} ${s*0.26},${s*0.34} ${s*0.44},${s*0.34}" fill="${c}" opacity="0.35"/><polygon points="${s/2},${s*0.26} ${s*0.54},${s*0.38} ${s*0.66},${s*0.38} ${s*0.57},${s*0.46} ${s*0.61},${s*0.59} ${s/2},${s*0.52} ${s*0.39},${s*0.59} ${s*0.43},${s*0.46} ${s*0.34},${s*0.38} ${s*0.46},${s*0.38}" fill="${c}" opacity="0.6"/><circle cx="${s/2}" cy="${s/2}" r="${s*0.075}" fill="${c}" opacity="0.9"/>`,
        fresh:    `<path d="M${s*0.2} ${s*0.57} Q${s*0.32} ${s*0.32} ${s/2} ${s*0.38} Q${s*0.68} ${s*0.32} ${s*0.8} ${s*0.57} Q${s*0.68} ${s*0.76} ${s/2} ${s*0.71} Q${s*0.32} ${s*0.76} ${s*0.2} ${s*0.57}Z" fill="${c}" opacity="0.15"/><path d="M${s*0.26} ${s*0.56} Q${s*0.35} ${s*0.38} ${s/2} ${s*0.43} Q${s*0.65} ${s*0.38} ${s*0.74} ${s*0.56} Q${s*0.65} ${s*0.72} ${s/2} ${s*0.67} Q${s*0.35} ${s*0.72} ${s*0.26} ${s*0.56}Z" fill="${c}" opacity="0.32"/><path d="M${s*0.33} ${s*0.55} Q${s*0.4} ${s*0.44} ${s/2} ${s*0.48} Q${s*0.6} ${s*0.44} ${s*0.67} ${s*0.55} Q${s*0.6} ${s*0.65} ${s/2} ${s*0.61} Q${s*0.4} ${s*0.65} ${s*0.33} ${s*0.55}Z" fill="${c}" opacity="0.55"/><circle cx="${s/2}" cy="${s*0.53}" r="${s*0.06}" fill="${c}" opacity="0.88"/>`,
        gourmand: `<circle cx="${s/2}" cy="${s/2}" r="${s*0.38}" fill="${c}" opacity="0.13"/><circle cx="${s/2}" cy="${s/2}" r="${s*0.28}" fill="${c}" opacity="0.28"/><circle cx="${s/2}" cy="${s/2}" r="${s*0.18}" fill="${c}" opacity="0.58"/><circle cx="${s/2}" cy="${s/2}" r="${s*0.09}" fill="${c}" opacity="0.85"/><path d="M${s*0.42} ${s*0.44} Q${s/2} ${s*0.39} ${s*0.58} ${s*0.44}" stroke="white" stroke-width="1.2" fill="none" opacity="0.38"/>`
      };
      return `<svg width="${s}" height="${s}" viewBox="0 0 ${s} ${s}" xmlns="http://www.w3.org/2000/svg">${shapes[icon] || shapes.oriental}</svg>`;
    }

    const pillStyle = {
      Citrus:   'background:rgba(232,168,74,0.12);color:#c8822a;border:1px solid rgba(232,168,74,0.3)',
      Floral:   'background:rgba(201,122,138,0.1);color:#b05a6a;border:1px solid rgba(201,122,138,0.25)',
      Woody:    'background:rgba(122,92,58,0.1);color:#7a5c3a;border:1px solid rgba(122,92,58,0.25)',
      Oriental: 'background:rgba(106,74,122,0.1);color:#6a4a7a;border:1px solid rgba(106,74,122,0.25)',
      Fresh:    'background:rgba(74,138,122,0.1);color:#4a8a7a;border:1px solid rgba(74,138,122,0.25)',
      Gourmand: 'background:rgba(154,90,74,0.1);color:#9a5a4a;border:1px solid rgba(154,90,74,0.25)'
    };

    const intensityLabel = v => v <= 30 ? 'Light' : v <= 50 ? 'Moderate' : v <= 70 ? 'Strong' : 'Very Strong';

    window.openNoteDrawer = function(key) {
      const n = NOTES[key];
      if (!n) return; // unknown key — drawer stays closed, no error shown to user

      document.getElementById('ndFamily').textContent = n.family + ' Family';
      document.getElementById('ndName').textContent = n.name;

      const img = document.getElementById('ndImage');
      img.innerHTML = getIllustration(n.icon, n.fc);
      img.style.background = n.fc + '18';

      document.getElementById('ndFamilyPill').innerHTML =
        `<span class="nd-family-pill" style="${pillStyle[n.family]||''};border-radius:100px;">${n.family}</span>`;
      document.getElementById('ndDesc').textContent = n.desc;
      document.getElementById('ndPairings').innerHTML =
        n.pairings.map(p => `<span class="nd-pair-tag">${p}</span>`).join('');

      const fill = document.getElementById('ndIntensityFill');
      fill.style.width = '0%';
      setTimeout(() => { fill.style.width = n.strength + '%'; }, 40);
      document.getElementById('ndIntensityValue').textContent = intensityLabel(n.strength);

      document.getElementById('ndBackdrop').classList.add('nd-open');
      document.getElementById('ndDrawer').classList.add('nd-open');
      document.body.style.overflow = 'hidden';
    };

    function closeNoteDrawer() {
      document.getElementById('ndBackdrop').classList.remove('nd-open');
      document.getElementById('ndDrawer').classList.remove('nd-open');
      document.body.style.overflow = '';
    }

    document.getElementById('ndClose').addEventListener('click', closeNoteDrawer);
    document.getElementById('ndBackdrop').addEventListener('click', closeNoteDrawer);
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeNoteDrawer(); });
  })();

  // ── Share button ──
  (function() {
    const wrap = document.getElementById('share-wrap');
    const btn = document.getElementById('btn-share');
    const copyBtn = document.getElementById('share-copy');
    const nativeBtn = document.getElementById('share-native');
    const whatsappBtn = document.getElementById('share-whatsapp');
    const copiedMsg = document.getElementById('share-copied');
    if (!wrap) return;

    const url = window.location.href;
    const title = document.querySelector('.product-name') ? document.querySelector('.product-name').textContent.trim() : document.title;
    const text = 'Check out ' + title + ' on YSP Collective';

    whatsappBtn.href = 'https://wa.me/?text=' + encodeURIComponent(text + ' — ' + url);

    if (navigator.share) {
      nativeBtn.style.display = 'flex';
      nativeBtn.addEventListener('click', function() {
        navigator.share({ title: title, text: text, url: url }).catch(function(){});
        wrap.classList.remove('open');
      });
    }

    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      wrap.classList.toggle('open');
    });

    document.addEventListener('click', function(e) {
      if (!wrap.contains(e.target)) wrap.classList.remove('open');
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') wrap.classList.remove('open');
    });

    copyBtn.addEventListener('click', function() {
      navigator.clipboard.writeText(url).then(function() {
        wrap.classList.remove('open');
        copiedMsg.classList.add('show');
        setTimeout(function() { copiedMsg.classList.remove('show'); }, 2000);
      }).catch(function() {
        const ta = document.createElement('textarea');
        ta.value = url; ta.style.position = 'fixed'; ta.style.opacity = '0';
        document.body.appendChild(ta); ta.select(); document.execCommand('copy');
        document.body.removeChild(ta);
        wrap.classList.remove('open');
        copiedMsg.classList.add('show');
        setTimeout(function() { copiedMsg.classList.remove('show'); }, 2000);
      });
    });
  })();
</script>
