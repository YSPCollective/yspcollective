<script>
  // ── GALLERY ──────────────────────────────────────────────────────────────
  const mainImg = document.getElementById('main-img');
  const prevBtn = document.getElementById('gallery-prev');
  const nextBtn = document.getElementById('gallery-next');
  const thumbs = [...document.querySelectorAll('.gallery-thumb')];
  let currentIndex = 0;

  function goToImage(index) {
    if (index < 0 || index >= thumbs.length) return;
    currentIndex = index;
    mainImg.style.opacity = '0';
    setTimeout(() => { mainImg.src = thumbs[index].dataset.src; mainImg.style.opacity = '1'; }, 150);
    thumbs.forEach(t => t.classList.remove('active'));
    thumbs[index].classList.add('active');
    prevBtn.classList.toggle('hidden', index === 0);
    nextBtn.classList.toggle('hidden', index === thumbs.length - 1);
  }
  if (thumbs.length > 1) nextBtn.classList.remove('hidden');
  thumbs.forEach((thumb, i) => thumb.addEventListener('click', () => goToImage(i)));
  prevBtn.addEventListener('click', () => goToImage(currentIndex - 1));
  nextBtn.addEventListener('click', () => goToImage(currentIndex + 1));
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight') goToImage(currentIndex + 1);
    if (e.key === 'ArrowLeft') goToImage(currentIndex - 1);
  });
  let touchStartX = 0;
  mainImg.addEventListener('touchstart', e => { touchStartX = e.changedTouches[0].screenX; }, { passive: true });
  mainImg.addEventListener('touchend', e => {
    const diff = touchStartX - e.changedTouches[0].screenX;
    if (Math.abs(diff) > 40) { if (diff > 0) goToImage(currentIndex + 1); else goToImage(currentIndex - 1); }
  });

  // ── TABS ────────────────────────────────────────────────────────────────
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
    });
  });

  // ── DETAILS TABLE ────────────────────────────────────────────────────────
  const detailsData = {{ product | detailsJson | safe }};
  const tbody = document.getElementById('details-tbody');
  if (tbody && detailsData) {
    detailsData.forEach(row => {
      const tr = document.createElement('tr');
      tr.innerHTML = `<td>${row.label}</td><td>${row.value}</td>`;
      tbody.appendChild(tr);
    });
  }

  // ── LANGUAGE ─────────────────────────────────────────────────────────────
  (function() {
    const lang = localStorage.getItem('ysp_lang') || 'en';
    if (lang === 'en') return;
    const productData = {
      name_pt: {{ ((product.pt and product.pt.name_pt) or '') | jsonify | safe }},
      description_short_pt: {{ ((product.pt and product.pt.description_short_pt) or '') | jsonify | safe }},
      description_full_pt: {{ ((product.pt and product.pt.description_full_pt) or '') | jsonify | safe }},
      ysp_thoughts_pt: {{ ((product.pt and product.pt.ysp_thoughts_pt) or '') | jsonify | safe }},
      name_es: {{ ((product.es and product.es.name_es) or '') | jsonify | safe }},
      description_short_es: {{ ((product.es and product.es.description_short_es) or '') | jsonify | safe }},
      description_full_es: {{ ((product.es and product.es.description_full_es) or '') | jsonify | safe }},
      ysp_thoughts_es: {{ ((product.es and product.es.ysp_thoughts_es) or '') | jsonify | safe }}
    };
    const suffix = lang === 'pt' ? '_pt' : '_es';
    const descShort = productData['description_short' + suffix];
    if (descShort) { const el = document.getElementById('pdp-desc-short'); if (el) el.textContent = descShort; }
    const descFull = productData['description_full' + suffix];
    if (descFull) { const el = document.getElementById('pdp-desc-full'); if (el) el.innerHTML = descFull; }
    const thoughts = productData['ysp_thoughts' + suffix];
    if (thoughts) { const el = document.getElementById('pdp-thoughts'); if (el) el.innerHTML = thoughts; }
    document.addEventListener('ysp:langchange', (e) => {
      const newLang = e.detail.lang;
      const newSuffix = newLang === 'pt' ? '_pt' : newLang === 'es' ? '_es' : null;
      const shortEl = document.getElementById('pdp-desc-short');
      const fullEl = document.getElementById('pdp-desc-full');
      const thoughtsEl = document.getElementById('pdp-thoughts');
      if (!newSuffix) {
        if (shortEl) shortEl.textContent = {{ product.description_short | jsonify | safe }};
        if (fullEl) fullEl.innerHTML = {{ product.description_full | jsonify | safe }};
        if (thoughtsEl) thoughtsEl.innerHTML = {{ product.ysp_thoughts | jsonify | safe }};
      } else {
        if (shortEl) shortEl.textContent = productData['description_short' + newSuffix] || {{ product.description_short | jsonify | safe }};
        if (fullEl) fullEl.innerHTML = productData['description_full' + newSuffix] || {{ product.description_full | jsonify | safe }};
        if (thoughtsEl) thoughtsEl.innerHTML = productData['ysp_thoughts' + newSuffix] || {{ product.ysp_thoughts | jsonify | safe }};
      }
    });
  })();

  // ── NOTIFY ME ────────────────────────────────────────────────────────────
  const notifyBtn = document.getElementById('btn-notify');
  if (notifyBtn) {
    notifyBtn.addEventListener('click', () => {
      document.getElementById('notify-popup').style.display = 'block';
      document.getElementById('notify-email').focus();
    });
  }
  async function submitNotify() {
    const email = document.getElementById('notify-email').value;
    if (!email || !email.includes('@')) return;
    try {
      await fetch('https://ysp-ai-proxy.rapid-shadow-439d.workers.dev/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, lang: window.YSP_LANG ? window.YSP_LANG.get() : 'en', product: '{{ product.name }}' })
      });
      document.getElementById('notify-success').style.display = 'block';
      document.getElementById('notify-email').style.display = 'none';
      document.querySelector('#notify-popup button').style.display = 'none';
    } catch(e) {}
  }

  // ── ADD TO CART ──────────────────────────────────────────────────────────
  const addToCartBtn = document.getElementById('btn-add-to-cart');
  if (addToCartBtn) {
    addToCartBtn.addEventListener('click', () => {
      if (window.YSPCart) {
        YSPCart.add({
          id: addToCartBtn.dataset.id,
          name: addToCartBtn.dataset.name,
          price: parseFloat(addToCartBtn.dataset.price),
          image: addToCartBtn.dataset.image,
          quantity: 1
        });
      }
    });
  }

  // ── BUY NOW ──────────────────────────────────────────────────────────────
  const buyBtn = document.getElementById('btn-buy-now');
  if (buyBtn) {
    buyBtn.addEventListener('click', async () => {
      buyBtn.textContent = 'Loading...';
      buyBtn.disabled = true;
      try {
        const image = buyBtn.dataset.image || '';
        const imageUrl = image.startsWith('http') ? image : 'https://yspcollective.com' + image;
        const lang = window.YSP_LANG ? window.YSP_LANG.get() : 'en';
        const res = await fetch('https://ysp-ai-proxy.rapid-shadow-439d.workers.dev/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            items: [{ id: buyBtn.dataset.slug, name: buyBtn.dataset.name, price: parseFloat(buyBtn.dataset.price), image: imageUrl, quantity: 1 }],
            success_url: 'https://yspcollective.com/checkout-success.html',
            cancel_url: window.location.href,
            lang,
          })
        });
        const data = await res.json();
        if (data.url) { window.location.href = data.url; }
        else { throw new Error(data.error || 'Checkout failed'); }
      } catch(err) {
        buyBtn.textContent = 'Buy Now';
        buyBtn.disabled = false;
        alert('Something went wrong. Please try again or use the enquiry form.');
      }
    });
  }

  // ── FAVOURITE BUTTON (product page) ─────────────────────────────────────
  window.addEventListener('load', function() {
    const favBtn = document.getElementById('btn-fav-pdp');
    if (!favBtn || !window.YSPAccount) return;

    if (YSPAccount.isLoggedIn()) {
      YSPAccount.getFavourites().then(data => {
        const isFav = (data.favourites || []).some(f => f.slug === favBtn.dataset.favSlug);
        if (isFav) {
          favBtn.classList.add('is-favourite');
          favBtn.textContent = '♥';
        }
      });
    }

    favBtn.addEventListener('click', async e => {
      e.preventDefault();
      e.stopPropagation();
      if (!YSPAccount.isLoggedIn()) {
        YSPAccount.showAuthModal('login', 'Sign in to save favourites');
        return;
      }
      const result = await YSPAccount.toggleFavourite({
        slug: favBtn.dataset.favSlug,
        name: favBtn.dataset.favName,
        price: favBtn.dataset.favPrice,
        image: favBtn.dataset.favImage,
        type: favBtn.dataset.favType
      });
      if (result) {
        const added = result.action === 'added';
        favBtn.classList.toggle('is-favourite', added);
        favBtn.textContent = added ? '♥' : '♡';
      }
    });
  });

  // ── NOTE DRAWER ──────────────────────────────────────────────────────────
  (function() {
    'use strict';

    const NOTES = {
      // ── CITRUS ──
      bergamot:     { name:'Bergamot',           family:'Citrus',   fc:'#e8a84a', icon:'citrus',   strength:30, desc:'The most refined citrus in perfumery — bergamot has a uniquely floral, slightly spicy character beneath its brightness. The defining note in Earl Grey tea, it bridges citrus and floral families and opens some of the world\'s most celebrated fragrances.', pairings:['Cedar','Lavender','Rose','Musk','Amber'] },
      lemon:        { name:'Lemon',              family:'Citrus',   fc:'#f0d060', icon:'citrus',   strength:25, desc:'Sharp, clean and instantly recognisable. Lemon adds a bright, fizzy luminosity to fragrances — the most transparent citrus note, used in fresh and aquatic compositions as an energising opener.', pairings:['Marine','White Musk','Vetiver','Cedar','Ginger'] },
      grapefruit:   { name:'Grapefruit',         family:'Citrus',   fc:'#f0a080', icon:'citrus',   strength:28, desc:'Juicy, slightly bitter and wonderfully uplifting. Grapefruit has a natural effervescence and a slight green, herbal edge. Popular in fresh and sport fragrances, it works beautifully against warm woody and musky bases.', pairings:['White Musk','Vetiver','Cedar','Jasmine','Amber'] },
      mandarin:     { name:'Mandarin',           family:'Citrus',   fc:'#e87030', icon:'citrus',   strength:35, desc:'Sweeter and rounder than other citrus notes, with a jammy, almost red-fruited quality that bridges citrus and gourmand families. Warmer and more sensual than lemon or bergamot.', pairings:['Rose','Sandalwood','Amber','Vanilla','Jasmine'] },
      citrus:       { name:'Citrus',             family:'Citrus',   fc:'#e8b84a', icon:'citrus',   strength:28, desc:'A bright, zesty family of notes drawn from the peels of oranges, lemons, limes and bergamot. Citrus accords open fragrances with immediate freshness and energy — they\'re the most volatile notes in perfumery, felt most strongly in the first 15–30 minutes. They bring lightness and lift to any composition.', pairings:['Musk','Cedar','Amber','Marine','Lavender'] },
      orange:       { name:'Orange',             family:'Citrus',   fc:'#f09030', icon:'citrus',   strength:30, desc:'Sunny, sweet and immediately uplifting. Orange is warmer and rounder than lemon — closer to mandarin — with a natural sweetness that makes it one of the most approachable citrus notes. It appears in countless fruity and oriental compositions, adding warmth without heaviness.', pairings:['Amber','Vanilla','Sandalwood','Jasmine','Musk'] },
      // ── FLORAL ──
      rose:         { name:'Rose',               family:'Floral',   fc:'#c06070', icon:'floral',   strength:55, desc:'The queen of flowers and the most used note in perfumery. Rose ranges from fresh and dewy to rich and jam-like. Central to Arabian perfumery — particularly in celebrated oud-rose combinations that are considered the pinnacle of Middle Eastern fragrance.', pairings:['Oud','Sandalwood','Amber','Musk','Bergamot'] },
      jasmine:      { name:'Jasmine',            family:'Floral',   fc:'#e8e0c8', icon:'floral',   strength:60, desc:'Intoxicating, rich and slightly animalic. Jasmine contains over 200 aromatic compounds and has an almost skin-like quality that makes it extraordinarily seductive — used in both feminine and masculine fragrances worldwide.', pairings:['Musk','Sandalwood','Amber','Rose','Vanilla'] },
      lavender:     { name:'Lavender',           family:'Floral',   fc:'#9080b0', icon:'floral',   strength:40, desc:'Aromatic, herbal and endlessly calming. Lavender straddles floral and aromatic families and underpins the classic fougère accord — the foundation of most traditional masculine fragrances.', pairings:['Oakmoss','Coumarin','Musk','Cedar','Bergamot'] },
      iris:         { name:'Iris',               family:'Floral',   fc:'#8070a0', icon:'floral',   strength:50, desc:'One of the rarest materials in perfumery, from orris root aged for several years. Iris has a powdery, violet-like quality with a clean metallic edge — associated with refinement and Parisian haute parfumerie.', pairings:['Violet','Cedar','Musk','Sandalwood','Rose'] },
      floral:       { name:'Floral',             family:'Floral',   fc:'#d07080', icon:'floral',   strength:50, desc:'The most diverse family in fragrance — spanning everything from light and airy to rich and opulent. Floral accords evoke freshly cut blooms: rose, jasmine, lily, peony, freesia and more. They form the heart of countless classic perfumes and are the most widely used accord in feminine and unisex compositions.', pairings:['Musk','Amber','Sandalwood','Bergamot','Vanilla'] },
      peony:        { name:'Peony',              family:'Floral',   fc:'#e090a0', icon:'floral',   strength:40, desc:'Light, airy and softly romantic. Peony has a clean, slightly watery floral character — fresher than rose, with a gentle green quality that makes it feel effortlessly modern. It\'s a staple of feminine and fruity-floral compositions, adding delicacy and a sense of spring without heaviness.', pairings:['Rose','Musk','Bergamot','Amber','Jasmine'] },
      lily:         { name:'Lily',               family:'Floral',   fc:'#e8d0b0', icon:'floral',   strength:45, desc:'Elegant, slightly creamy and intensely floral. Lily of the valley is delicate and dewy; oriental lily is richer and more opulent. Both bring a classic, feminine quality that works beautifully in floral-oriental and floral-woody compositions.', pairings:['Rose','Jasmine','Musk','Sandalwood','Amber'] },
      violet:       { name:'Violet',             family:'Floral',   fc:'#9070b0', icon:'floral',   strength:45, desc:'Powdery, slightly sweet and distinctly retro. Violet has a unique character — simultaneously floral and earthy, with a cool, almost metallic quality that echoes iris. It adds a soft, nostalgic depth to compositions and bridges floral and woody families gracefully.', pairings:['Iris','Rose','Musk','Cedar','Bergamot'] },
      // ── WOODY ──
      oud:          { name:'Oud (Agarwood)',      family:'Woody',    fc:'#5a3010', icon:'woody',    strength:90, desc:'The most precious material in all perfumery — sometimes called liquid gold. Oud comes from agarwood infected with a specific mould, producing a smoky, deep, extraordinarily complex scent. The defining note of Middle Eastern perfumery.', pairings:['Rose','Amber','Saffron','Sandalwood','Musk'] },
      sandalwood:   { name:'Sandalwood',          family:'Woody',    fc:'#c0906a', icon:'woody',    strength:65, desc:'Creamy, milky and deeply sensual. Sandalwood blends seamlessly with almost any ingredient, smoothing rough edges and adding warm, skin-like depth. A cornerstone of both Arabian and European perfumery traditions.', pairings:['Rose','Jasmine','Vanilla','Musk','Amber'] },
      cedarwood:    { name:'Cedarwood',           family:'Woody',    fc:'#8a6040', icon:'woody',    strength:50, desc:'Clean, dry and pencil-shaving dry. Cedar provides woody structure without overwhelming other notes — at home in fresh aquatics, classic masculines and rich orientals alike.', pairings:['Bergamot','Vetiver','Musk','Amber','Lavender'] },
      vetiver:      { name:'Vetiver',             family:'Woody',    fc:'#706040', icon:'woody',    strength:70, desc:'Earthy, smoky, rooty and profoundly grounding. Extracted from roots of a grass native to India and Haiti. Adds gravitas, depth and a wonderful dry quality to woody and aromatic compositions.', pairings:['Bergamot','Cedar','Oakmoss','Amber','Grapefruit'] },
      woody:        { name:'Woody',              family:'Woody',    fc:'#7a5c3a', icon:'woody',    strength:60, desc:'Warm, grounding and deeply sensual. Woody accords form the backbone of most oriental and masculine compositions — providing depth, longevity and a sense of natural comfort. They\'re responsible for the dry-down: the final, lasting phase of a fragrance where the truest character emerges.', pairings:['Amber','Musk','Sandalwood','Vetiver','Cedar'] },
      patchouli:    { name:'Patchouli',          family:'Woody',    fc:'#6a5030', icon:'woody',    strength:75, desc:'Earthy, dark, slightly sweet and deeply hypnotic. Patchouli is one of the most divisive notes in perfumery — unmistakable and powerful. It anchors oriental and chypre compositions with a rich, almost fermented earthiness that becomes smoother and more beautiful with age. A cornerstone of many iconic Arabian fragrances.', pairings:['Rose','Amber','Vanilla','Oud','Sandalwood'] },
      tobacco:      { name:'Tobacco',            family:'Woody',    fc:'#7a5020', icon:'woody',    strength:70, desc:'Warm, slightly sweet and deeply masculine. Tobacco in perfumery captures the cured, honeyed quality of fine tobacco leaf rather than smoke. It adds an addictive warmth and richness to oriental and gourmand compositions — pairing beautifully with vanilla, amber and leather for evening fragrances of real character.', pairings:['Vanilla','Amber','Leather','Coffee','Musk'] },
      leather:      { name:'Leather',            family:'Woody',    fc:'#6a4030', icon:'woody',    strength:65, desc:'Smoky, animalic and deeply sophisticated. Leather accords in perfumery evoke everything from fresh suede to aged birch tar — adding a distinctly adult, confident quality to compositions. Often used in oriental and chypre fragrances, leather is a hallmark of the great Middle Eastern oud-leather tradition.', pairings:['Oud','Amber','Saffron','Tobacco','Musk'] },
      // ── ORIENTAL / SPICY ──
      amber:        { name:'Amber',              family:'Oriental', fc:'#b08030', icon:'oriental', strength:75, desc:'Warm, honeyed, powdery and deeply comforting. Amber is an accord combining labdanum, benzoin, vanilla and sandalwood — the most iconic accord in Arabian perfumery, adding opulence and longevity to oriental compositions.', pairings:['Oud','Musk','Rose','Vanilla','Sandalwood'] },
      musk:         { name:'Musk',               family:'Oriental', fc:'#7a6060', icon:'oriental', strength:45, desc:'The most intimate of all fragrance materials. Musks range from clean and soapy to animalic and earthy to warm and skin-like. Musk gives fragrances their second-skin quality — making them feel personal and irreplaceable.', pairings:['Amber','Vanilla','Sandalwood','Rose','Bergamot'] },
      saffron:      { name:'Saffron',            family:'Oriental', fc:'#c06810', icon:'oriental', strength:80, desc:'Intensely spicy, leathery and metallic. Simultaneously sharp and sweet, with a leather-like facet that adds incredible depth. A signature note in Arabian luxury perfumery — particularly in premium oud compositions.', pairings:['Oud','Rose','Amber','Sandalwood','Musk'] },
      incense:      { name:'Incense / Frankincense', family:'Oriental', fc:'#806030', icon:'oriental', strength:70, desc:'Smoky, resinous, ceremonial and profound. Frankincense has a crystalline, slightly lemony quality beneath the resin. A cornerstone of Arabic bakhoor tradition — adds a timeless, sacred quality to oriental fragrances.', pairings:['Oud','Amber','Rose','Sandalwood','Musk'] },
      frankincense: { name:'Frankincense',       family:'Oriental', fc:'#806030', icon:'oriental', strength:70, desc:'Smoky, resinous, ceremonial and profound. Frankincense has a crystalline, slightly lemony quality beneath the resin. A cornerstone of Arabic bakhoor tradition — adds a timeless, sacred quality to oriental fragrances.', pairings:['Oud','Amber','Rose','Sandalwood','Musk'] },
      spicy:        { name:'Spicy',              family:'Oriental', fc:'#a05020', icon:'oriental', strength:65, desc:'A warm, peppery family of accords drawn from cloves, cinnamon, cardamom, black pepper and other spices. Spicy notes add immediate energy and character to fragrances — they\'re perceived as bold and self-assured. In Arabian perfumery, spice is used to add complexity and heat to oud and amber-based compositions.', pairings:['Amber','Oud','Musk','Sandalwood','Vanilla'] },
      warmspicy:    { name:'Warm Spicy',         family:'Oriental', fc:'#b06030', icon:'oriental', strength:68, desc:'The most seductive spice accord — combining warming spices like cinnamon, clove, cardamom and nutmeg with a rich oriental base. Warm spicy compositions feel comforting and enveloping, like expensive cashmere. A defining character of premium Arabian fragrances — sensual, bold and long-lasting.', pairings:['Amber','Oud','Vanilla','Sandalwood','Musk'] },
      freshspicy:   { name:'Fresh Spicy',        family:'Oriental', fc:'#909050', icon:'oriental', strength:50, desc:'A modern accord that balances the energy of citrus and green notes with the warmth of spice. Black pepper, ginger and pink pepper are typical fresh spice ingredients — adding a lively, crisp warmth rather than the heavy heat of cinnamon or clove. Popular in contemporary masculine and unisex fragrances.', pairings:['Bergamot','Cedarwood','Musk','Ginger','Vetiver'] },
      oriental:     { name:'Oriental',           family:'Oriental', fc:'#7a5080', icon:'oriental', strength:72, desc:'The richest, most complex family in perfumery. Oriental fragrances are warm, exotic and deeply layered — drawing on resins, spices, incense and rare botanical extracts. This is the heartland of Arabian fragrance, where accords like amber, oud and bakhoor create compositions with legendary longevity and extraordinary presence.', pairings:['Amber','Oud','Musk','Vanilla','Sandalwood'] },
      resinous:     { name:'Resinous',           family:'Oriental', fc:'#906830', icon:'oriental', strength:70, desc:'Deep, sticky-sweet and intensely warm. Resinous notes come from tree saps and balsams — benzoin, labdanum, myrrh, elemi. They add a honeyed, almost incense-like richness that is fundamental to oriental and bakhoor compositions. Resinous bases give fragrances incredible longevity and a warm, glowing drydown.', pairings:['Amber','Oud','Incense','Vanilla','Sandalwood'] },
      balsamic:     { name:'Balsamic',           family:'Oriental', fc:'#8a6828', icon:'oriental', strength:65, desc:'Sweet, warm and slightly medicinal. Balsamic notes are derived from tree resins and balsams — benzoin, styrax, Peru balsam, tolu. They add a smooth, vanilla-adjacent warmth and a slightly medicinal sweetness that softens and rounds compositions. A hallmark of classic oriental and amber fragrances.', pairings:['Vanilla','Amber','Sandalwood','Musk','Incense'] },
      cardamom:     { name:'Cardamom',           family:'Oriental', fc:'#7a8a40', icon:'oriental', strength:60, desc:'Spicy, green, slightly eucalyptus-like and addictively complex. Cardamom is one of the most versatile spices in perfumery — warm enough for oriental compositions, fresh enough for lighter fragrances. It adds a sophisticated, exotic warmth that bridges the spicy and fresh families. Heavily used in Arabic attars and luxury oud blends.', pairings:['Rose','Oud','Amber','Cedar','Musk'] },
      cinnamon:     { name:'Cinnamon',           family:'Oriental', fc:'#c07030', icon:'oriental', strength:70, desc:'Sweet, warm and intensely spicy. Cinnamon is one of the most recognised spices in the world and in perfumery it brings an immediate sense of warmth and richness. It adds a seductive heat to oriental and gourmand compositions — often used alongside amber, vanilla and oud in Arabian fragrances for an opulent, enveloping character.', pairings:['Vanilla','Amber','Oud','Clove','Musk'] },
      // ── FRESH ──
      marine:       { name:'Marine / Aquatic',   family:'Fresh',    fc:'#4080a0', icon:'fresh',    strength:35, desc:'Clean, airy and oceanic. Marine notes are largely synthetic, evoking sea air, ozone and wet stone. They add a sense of openness and freedom to compositions — fresh and effortless without being lightweight.', pairings:['Citrus','Musk','Cedar','Lavender','Grapefruit'] },
      aquatic:      { name:'Aquatic',            family:'Fresh',    fc:'#4888b0', icon:'fresh',    strength:35, desc:'Clean, airy and oceanic. Aquatic notes evoke sea air, ozone and wet stone through largely synthetic ingredients. They add a sense of openness and freedom to compositions — perfect for light, easy-wearing fragrances that feel alive and energetic.', pairings:['Citrus','Musk','Cedar','Lavender','Grapefruit'] },
      greenTea:     { name:'Green Tea',          family:'Fresh',    fc:'#70a060', icon:'fresh',    strength:30, desc:'Delicately vegetal, subtly bitter and wonderfully clean. Green tea notes capture freshly steeped sencha — grassy, slightly smoky and refreshingly simple. A staple of K-beauty fragrances and light oriental compositions.', pairings:['Bergamot','White Musk','Cedar','Jasmine','Lemon'] },
      mint:         { name:'Mint',               family:'Fresh',    fc:'#50b070', icon:'fresh',    strength:40, desc:'Cool, sharp and immediately invigorating. Used sparingly to add a burst of coolness and contrast — works well in aromatic fougères and as a counterpoint to warm oriental bases.', pairings:['Lavender','Bergamot','Vetiver','Musk','Cedar'] },
      fresh:        { name:'Fresh',              family:'Fresh',    fc:'#4a9a7a', icon:'fresh',    strength:32, desc:'Clean, airy and effortless. Fresh accords are created both synthetically and from natural sources to evoke everything from ocean breezes to crisp linen and morning dew. They\'re the foundation of lighter, daytime fragrances and often used to balance heavier oriental or woody compositions.', pairings:['Citrus','Musk','Cedar','Lavender','Marine'] },
      aromatic:     { name:'Aromatic',           family:'Fresh',    fc:'#5a8a60', icon:'fresh',    strength:45, desc:'Herbal, green and pleasantly medicinal. Aromatic notes are drawn from herbs like rosemary, sage, thyme, basil and lavender — plants whose scent comes from volatile essential oils rather than flowers. Aromatic accords add a natural, outdoorsy freshness to compositions and are fundamental to the classic fougère family — the backbone of most traditional masculine fragrances.', pairings:['Lavender','Cedar','Musk','Vetiver','Bergamot'] },
      green:        { name:'Green',              family:'Fresh',    fc:'#5a9050', icon:'fresh',    strength:38, desc:'Crisp, vegetal and alive. Green notes evoke freshly cut grass, crushed leaves, fig leaves and cucumber — the smell of living plants. They add an immediate naturalness and vitality to compositions, lightening heavy oriental bases and adding a contemporary edge to classic floral structures.', pairings:['Bergamot','Jasmine','Musk','Cedar','Rose'] },
      // ── GOURMAND ──
      vanilla:      { name:'Vanilla',            family:'Gourmand', fc:'#c0902a', icon:'gourmand', strength:60, desc:'Warm, creamy and universally comforting. Vanilla adds warmth, sweetness and skin-like softness that makes compositions feel intimate. It underpins the oriental drydown that makes Arabian fragrances so addictive and long-lasting.', pairings:['Amber','Musk','Sandalwood','Rose','Oud'] },
      caramel:      { name:'Caramel',            family:'Gourmand', fc:'#a06020', icon:'gourmand', strength:55, desc:'Rich, buttery and deeply sweet. Caramel notes add a warm, enveloping sweetness — popular in evening and winter fragrances, sitting comfortably alongside amber, vanilla and warm musks in oriental compositions.', pairings:['Vanilla','Amber','Musk','Tonka Bean','Sandalwood'] },
      coffee:       { name:'Coffee',             family:'Gourmand', fc:'#604020', icon:'gourmand', strength:65, desc:'Dark, roasted, intensely aromatic. Coffee adds incredible depth and a modern character — particularly prominent in fragrances like Lattafa Khamrah Qahwa where it forms the centrepiece of the composition.', pairings:['Vanilla','Tobacco','Amber','Musk','Cedar'] },
      tonkaBean:    { name:'Tonka Bean',         family:'Gourmand', fc:'#906838', icon:'gourmand', strength:50, desc:'Almondine, sweet and warmly powdery. Tonka bean bridges gourmand and oriental families, adding soft comforting sweetness without cloying weight. Essential for softening spicy and woody notes in oriental perfumery.', pairings:['Vanilla','Lavender','Musk','Amber','Cedarwood'] },
      sweet:        { name:'Sweet',              family:'Gourmand', fc:'#c07860', icon:'gourmand', strength:55, desc:'Warm, enveloping and immediately appealing. Sweet accords encompass vanilla, caramel, praline, cotton candy and sugar — the edible side of perfumery. They make fragrances feel approachable, comforting and modern. Sweet notes are enormously popular in contemporary Arabian and niche fragrances, adding an addictive, wearable quality that lasts through the drydown.', pairings:['Vanilla','Amber','Musk','Tonka Bean','Sandalwood'] },
      fruity:       { name:'Fruity',             family:'Gourmand', fc:'#d06858', icon:'gourmand', strength:48, desc:'Juicy, vibrant and instantly likeable. Fruity accords span everything from fresh citrus and crisp apple to rich red berries, tropical mango and jammy plum. They add sweetness and colour to compositions without the heaviness of gourmand notes. Fruity accords are hugely popular in modern feminine and unisex fragrances, particularly in the opening and heart phases.', pairings:['Rose','Musk','Amber','Jasmine','Vanilla'] },
      tropical:     { name:'Tropical',           family:'Gourmand', fc:'#d08040', icon:'gourmand', strength:45, desc:'Lush, sun-drenched and escapist. Tropical notes evoke warm climates and exotic fruits — mango, passion fruit, coconut, tiare flower and frangipani. They bring an immediate sense of warmth and joy to compositions, adding a vibrant sweetness that works beautifully in fresh florals and summer fragrances. Increasingly popular in modern Arabian compositions that blend eastern richness with tropical brightness.', pairings:['Vanilla','Jasmine','Musk','Sandalwood','Citrus'] },
      coconut:      { name:'Coconut',            family:'Gourmand', fc:'#d0b070', icon:'gourmand', strength:50, desc:'Creamy, sweet and unmistakably sun-soaked. Coconut in perfumery adds a milky, tropical warmth that bridges the gourmand and fresh families. It pairs beautifully with floral notes, sandalwood and vanilla to create compositions that feel simultaneously warm and airy — perfect for warm-weather and resort-inspired fragrances.', pairings:['Vanilla','Jasmine','Sandalwood','Musk','Tiare'] }
    };

