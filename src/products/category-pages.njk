---
layout: base.njk
pagination:
  data: categories
  size: 1
  alias: cat
permalink: "{{ cat.permalink }}"
eleventyComputed:
  title: "{{ cat.title_en }} — YSP Collective"
  description: "{{ cat.description_en }}"
---

{% block head_extra %}
<style>
  .cat-hero {
    position: relative;
    height: 45vh;
    min-height: 320px;
    overflow: hidden;
    background: var(--black);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cat-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.55;
  }
  .cat-hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(26,25,22,0.7) 0%, rgba(26,25,22,0.1) 60%, transparent 100%),
      linear-gradient(to top, rgba(26,25,22,0.6) 0%, transparent 60%);
  }
  .cat-hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 2rem;
  }
  .cat-hero-label {
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--accent-light);
    margin-bottom: 1rem;
    display: block;
  }
  .cat-hero-title {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 300;
    color: var(--white);
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .cat-body {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 4rem 6rem;
  }

  .cat-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--sand);
  }
  .cat-count {
    font-size: 0.78rem;
    color: var(--grey);
    letter-spacing: 0.05em;
  }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.8rem;
  }

  .cat-product-card {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 0.3s;
  }
  .cat-product-card:hover { transform: translateY(-4px); }
  .cat-product-img {
    aspect-ratio: 3/4;
    background: var(--cream);
    overflow: hidden;
    position: relative;
    margin-bottom: 1rem;
  }
  .cat-product-img img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
  }
  .cat-product-card:hover .cat-product-img img { transform: scale(1.04); }
  .cat-product-badge {
    position: absolute;
    top: 0.7rem;
    left: 0.7rem;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    background: var(--accent);
    color: var(--white);
    z-index: 1;
  }
  .cat-product-meta {
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--grey-light);
    margin-bottom: 0.3rem;
  }
  .cat-product-name {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 400;
    line-height: 1.3;
    margin-bottom: 0.3rem;
  }
  .cat-product-price {
    font-size: 0.95rem;
    color: var(--accent);
    font-weight: 400;
  }

  .cat-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 5rem 2rem;
    color: var(--grey);
    border: 1px solid var(--sand);
  }
  .cat-empty p { font-size: 0.9rem; line-height: 1.7; }

  @media (max-width: 1024px) { .cat-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 768px) {
    .cat-body { padding: 2.5rem 1.5rem 4rem; }
    .cat-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .cat-hero-content { text-align: left; }
  }
</style>
{% endblock %}

<!-- HERO -->
<section class="cat-hero">
  <div class="cat-hero-bg" style="background-image: url('{{ cat.hero_image }}');"></div>
  <div class="cat-hero-overlay"></div>
  <div class="cat-hero-content">
    <span class="cat-hero-label">{{ cat.section | capitalize }}</span>
    <h1 class="cat-hero-title" data-i18n-cat-title="{{ cat.slug }}">{{ cat.title_en }}</h1>
  </div>
</section>

<!-- PRODUCTS -->
<div class="cat-body">
  {% if cat.filter_type === "gender" %}
    {% set filteredProducts = collections.allProducts | selectattr("gender") %}
    {% set catProducts = [] %}
    {% for p in collections.allProducts %}
      {% if p.gender === cat.filter_value %}
        {% set catProducts = (catProducts.push(p), catProducts) %}
      {% endif %}
    {% endfor %}
  {% elif cat.filter_type === "type" %}
    {% set catProducts = [] %}
    {% for p in collections.allProducts %}
      {% if p.type === cat.filter_value %}
        {% set catProducts = (catProducts.push(p), catProducts) %}
      {% endif %}
    {% endfor %}
  {% elif cat.filter_type === "category" %}
    {% set catProducts = [] %}
    {% for p in collections.allProducts %}
      {% if p.category and cat.filter_value in p.category %}
        {% set catProducts = (catProducts.push(p), catProducts) %}
      {% endif %}
    {% endfor %}
  {% endif %}

  <div class="cat-meta">
    <span class="cat-count">{{ catProducts.length }} product{% if catProducts.length !== 1 %}s{% endif %}</span>
  </div>

  <div class="cat-grid">
    {% if catProducts.length %}
      {% for p in catProducts %}
      <a href="/products/{{ p.slug }}.html" class="cat-product-card">
        <div class="cat-product-img">
          <img src="{{ p.image_main }}" alt="{{ p.name }}" loading="lazy">
          {% set b = p.custom_badge or p.badge %}
          {% if b %}<span class="cat-product-badge">{{ b }}</span>{% endif %}
        </div>
        <div class="cat-product-meta">{{ p.brand }} · {{ p.concentration or p.category }}</div>
        <div class="cat-product-name">{{ p.name }}</div>
        <div class="cat-product-price">€{{ p.price }}</div>
      </a>
      {% endfor %}
    {% else %}
      <div class="cat-empty">
        <p>More products coming soon.<br>
        <a href="mailto:info@yspcollective.com" style="color:var(--accent)">Contact us</a> if you're looking for something specific.</p>
      </div>
    {% endif %}
  </div>
</div>

<script>
  // Translate category title based on active language
  (function() {
    const titles = {
      "{{ cat.slug }}": {
        en: "{{ cat.title_en }}",
        pt: "{{ cat.title_pt }}",
        es: "{{ cat.title_es }}"
      }
    };
    const lang = localStorage.getItem('ysp_lang') || 'pt';
    const el = document.querySelector('[data-i18n-cat-title="{{ cat.slug }}"]');
    if (el && titles["{{ cat.slug }}"][lang]) {
      el.textContent = titles["{{ cat.slug }}"][lang];
    }
  })();
</script>
