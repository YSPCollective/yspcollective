  <script>
    // ── Announcement bar & nav offset ──
    function adjustNavTop() {
      const bar = document.getElementById('announcement-bar');
      const nav = document.getElementById('main-nav');
      if (bar && nav) {
        nav.style.top = (bar.style.display === 'none' ? 0 : bar.offsetHeight) + 'px';
      }
    }
    adjustNavTop();

    // ── Nav scroll ──
    const nav = document.getElementById('main-nav');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 60);
    }, { passive: true });

    // ── Mobile menu (separate overlay) ──
    const navToggle = document.getElementById('nav-toggle');
    const mobileMenu = document.getElementById('mobile-menu');

    function openMobileMenu() {
      mobileMenu.classList.add('open');
      mobileMenu.setAttribute('aria-hidden', 'false');
      navToggle.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeMobileMenu() {
      mobileMenu.classList.remove('open');
      mobileMenu.setAttribute('aria-hidden', 'true');
      navToggle.classList.remove('open');
      document.body.style.overflow = '';
      document.querySelectorAll('.mobile-dd-wrap').forEach(w => w.classList.remove('open'));
    }

    navToggle.addEventListener('click', () => {
      mobileMenu.classList.contains('open') ? closeMobileMenu() : openMobileMenu();
    });

    document.getElementById('mobile-menu-close').addEventListener('click', closeMobileMenu);

    // Mobile dropdown toggles
    document.querySelectorAll('.mobile-dd-trigger').forEach(trigger => {
      trigger.addEventListener('click', () => {
        const wrap = trigger.parentElement;
        const isOpen = wrap.classList.contains('open');
        document.querySelectorAll('.mobile-dd-wrap').forEach(w => w.classList.remove('open'));
        if (!isOpen) wrap.classList.add('open');
      });
    });

    // Close on link tap
    document.querySelectorAll('#mobile-menu a').forEach(a => {
      a.addEventListener('click', closeMobileMenu);
    });

    // Reset on resize to desktop
    window.addEventListener('resize', () => {
      if (window.innerWidth > 768) {
        closeMobileMenu();
        document.body.style.overflow = '';
      }
    });

    // ── Desktop nav-links show/hide ──
    const navLinks = document.getElementById('nav-links');

    // ── Dropdown logic ──
    document.querySelectorAll('.nav-dropdown-wrap').forEach(wrap => {
      const trigger = wrap.querySelector('.nav-dropdown-trigger');
      let closeTimer;
      const isMobile = () => window.innerWidth <= 768;

      // Mobile: tap trigger to toggle
      trigger.addEventListener('click', (e) => {
        if (isMobile()) {
          e.stopPropagation();
          const isOpen = wrap.classList.contains('open');
          // Close all others
          document.querySelectorAll('.nav-dropdown-wrap').forEach(w => w.classList.remove('open'));
          if (!isOpen) wrap.classList.add('open');
          trigger.setAttribute('aria-expanded', !isOpen);
        }
      });

      // Desktop: hover with delay
      wrap.addEventListener('mouseenter', () => {
        if (!isMobile()) {
          clearTimeout(closeTimer);
          wrap.classList.add('open');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
      wrap.addEventListener('mouseleave', () => {
        if (!isMobile()) {
          closeTimer = setTimeout(() => {
            wrap.classList.remove('open');
            trigger.setAttribute('aria-expanded', 'false');
          }, 150);
        }
      });
    });

    // Close dropdowns on outside click
    document.addEventListener('click', (e) => {
      if (!e.target.closest('.nav-dropdown-wrap')) {
        document.querySelectorAll('.nav-dropdown-wrap').forEach(w => w.classList.remove('open'));
      }
    });

    // ── Scroll reveal ──
    const reveals = document.querySelectorAll('.reveal');
    const ro = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => entry.target.classList.add('visible'), i * 60);
          ro.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08 });
    reveals.forEach(el => ro.observe(el));

    // ── Enquiry prefill from sessionStorage ──
    window.addEventListener('DOMContentLoaded', () => {
      const subject = sessionStorage.getItem('enquiry_subject');
      if (subject) {
        const input = document.querySelector('#contact input[name="subject"]');
        if (input) input.value = subject;
        sessionStorage.removeItem('enquiry_subject');
      }
    });
  </script>

