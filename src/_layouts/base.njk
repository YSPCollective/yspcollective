<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{ title }} — YSP Collective</title>
  <meta name="description" content="{{ description or 'Curated beauty, fragrance and lifestyle products. Sourced with care, delivered across Europe from Portugal.' }}">
  {% if canonical %}<link rel="canonical" href="{{ canonical }}">{% endif %}
  {% if schema %}<script type="application/ld+json">{{ schema | safe }}</script>{% endif %}

  <!-- Google Analytics GA4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-SPR047XTDH"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-SPR047XTDH', { 'anonymize_ip': true });
  </script>

  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <meta name="theme-color" content="#1a1916">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Outfit:wght@200;300;400;500&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --black: #1a1916;
      --white: #faf8f5;
      --cream: #f3efe8;
      --sand: #e6dfd4;
      --grey: #8a847a;
      --grey-light: #b5afa5;
      --accent: #9c7b56;
      --accent-light: #c8a87a;
      --serif: 'Playfair Display', Georgia, serif;
      --sans: 'Outfit', -apple-system, sans-serif;
      --nav-height: 80px;
      --banner-height: 40px;
      --ease: cubic-bezier(0.4, 0, 0.2, 1);
    }
    html { scroll-behavior: smooth; }
    body { background: var(--white); color: var(--black); font-family: var(--sans); font-weight: 300; overflow-x: hidden; -webkit-font-smoothing: antialiased; }
    a { color: inherit; }

    /* BANNER */
    #shipping-banner {
      background: var(--black);
      color: rgba(255,255,255,0.8);
      text-align: center;
      font-size: 0.72rem;
      letter-spacing: 0.06em;
      padding: 0;
      height: var(--banner-height);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      z-index: 1001;
    }
    .banner-inner {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      padding: 0 3rem;
      width: 100%;
    }
    .banner-text { flex: 1; text-align: center; }
    .banner-close {
      background: none;
      border: none;
      color: rgba(255,255,255,0.4);
      cursor: pointer;
      font-size: 0.8rem;
      padding: 0.2rem;
      position: absolute;
      right: 1rem;
      transition: color 0.2s;
    }
    .banner-close:hover { color: var(--white); }

    /* NAV */
    nav {
      position: fixed; top: var(--banner-height); left: 0; right: 0; z-index: 1000;
      display: flex; justify-content: space-between; align-items: center;
      padding: 0 3.5rem; height: var(--nav-height);
      background: rgba(250,248,245,0.94); backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(0,0,0,0.04);
      transition: height 0.4s var(--ease), box-shadow 0.4s var(--ease);
    }
    nav.scrolled { height: 64px; box-shadow: 0 1px 20px rgba(0,0,0,0.04); }
    .nav-logo { text-decoration: none; display: flex; align-items: center; gap: 0.6rem; }
    .nav-logo-text { font-family: var(--serif); font-size: 1.6rem; font-weight: 300; letter-spacing: 0.06em; color: var(--black); transition: font-size 0.4s var(--ease); }
    nav.scrolled .nav-logo-text { font-size: 1.3rem; }
    .nav-logo-sub { font-family: var(--sans); font-size: 0.55rem; letter-spacing: 0.35em; text-transform: uppercase; color: var(--grey); display: block; margin-top: -2px; }
    .nav-links { display: flex; gap: 2.2rem; list-style: none; align-items: center; }
    .nav-links a { font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--grey); text-decoration: none; transition: color 0.25s; font-weight: 400; }
    .nav-links a:hover { color: var(--accent); }
    .nav-cta { padding: 0.55rem 1.5rem; background: var(--accent); color: var(--white) !important; font-size: 0.7rem !important; transition: background 0.25s, transform 0.25s; }
    .nav-cta:hover { background: var(--black) !important; transform: translateY(-1px); }

    /* WHATSAPP */
    .nav-whatsapp {
      display: flex;
      align-items: center;
      color: #25D366;
      transition: transform 0.2s, color 0.2s;
      text-decoration: none;
    }
    .nav-whatsapp:hover { transform: scale(1.15); color: #1da851; }

    /* LANGUAGE SWITCHER */
    #ysp-lang-switcher {
      display: flex;
      align-items: center;
      gap: 0.2rem;
      margin-left: 1rem;
      border-left: 1px solid var(--sand);
      padding-left: 1rem;
    }
    .lang-btn {
      display: flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.3rem 0.5rem;
      background: none;
      border: 1px solid transparent;
      cursor: pointer;
      font-family: var(--sans);
      font-size: 0.65rem;
      font-weight: 400;
      letter-spacing: 0.1em;
      color: var(--grey);
      transition: all 0.2s;
      border-radius: 2px;
    }
    .lang-btn:hover { color: var(--accent); border-color: var(--sand); }
    .lang-btn.active { color: var(--black); border-color: var(--accent); background: rgba(156,123,86,0.06); }
    .lang-flag { font-size: 0.85rem; line-height: 1; }
    .lang-code { font-size: 0.65rem; letter-spacing: 0.1em; }

    .nav-toggle { display: none; background: none; border: none; cursor: pointer; width: 28px; height: 20px; position: relative; }
    .nav-toggle span { display: block; width: 100%; height: 1.5px; background: var(--black); position: absolute; left: 0; transition: all 0.3s; }
    .nav-toggle span:nth-child(1) { top: 0; }
    .nav-toggle span:nth-child(2) { top: 50%; transform: translateY(-50%); }
    .nav-toggle span:nth-child(3) { bottom: 0; }
    .nav-toggle.open span:nth-child(1) { top: 50%; transform: translateY(-50%) rotate(45deg); }
    .nav-toggle.open span:nth-child(2) { opacity: 0; }
    .nav-toggle.open span:nth-child(3) { bottom: 50%; transform: translateY(50%) rotate(-45deg); }

    /* FOOTER */
    footer { padding: 4rem 3.5rem 2rem; background: var(--black); color: rgba(255,255,255,0.4); }
    .footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; margin-bottom: 3rem; }
    .footer-brand .footer-logo-text { font-family: var(--serif); font-size: 1.4rem; font-weight: 300; color: var(--white); letter-spacing: 0.06em; }
    .footer-brand .footer-logo-sub { font-size: 0.55rem; letter-spacing: 0.35em; text-transform: uppercase; color: rgba(255,255,255,0.3); display: block; }
    .footer-brand p { font-size: 0.85rem; line-height: 1.7; margin-top: 1rem; color: rgba(255,255,255,0.35); }
    .footer-col h4 { font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.55); margin-bottom: 1.2rem; font-weight: 400; }
    .footer-col a { display: block; font-size: 0.85rem; color: rgba(255,255,255,0.35); text-decoration: none; margin-bottom: 0.6rem; transition: color 0.25s; }
    .footer-col a:hover { color: var(--accent-light); }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,0.06); padding-top: 1.5rem; display: flex; justify-content: space-between; font-size: 0.72rem; }

    /* REVEAL */
    .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.8s var(--ease), transform 0.8s var(--ease); }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* SECTION UTILS */
    .section-label { font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.2rem; font-weight: 400; }
    .section-title { font-family: var(--serif); font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 300; line-height: 1.2; margin-bottom: 1.5rem; }
    .section-desc { font-size: 0.95rem; line-height: 1.8; color: var(--grey); max-width: 520px; }

    /* PRODUCT CARDS */
    .product-card { text-decoration: none; color: inherit; display: block; position: relative; transition: transform 0.4s var(--ease); }
    .product-card:hover { transform: translateY(-4px); }
    .product-card-image { aspect-ratio: 3/4; background: var(--cream); overflow: hidden; position: relative; margin-bottom: 1.2rem; }
    .product-card-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s var(--ease); }
    .product-card:hover .product-card-image img { transform: scale(1.04); }
    .product-badge { position: absolute; top: 0.8rem; left: 0.8rem; font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase; padding: 0.3rem 0.7rem; background: var(--accent); color: var(--white); font-weight: 400; }
    .product-badge.badge-popular { background: var(--grey); }
    .product-badge.badge-curated { background: var(--black); }
    .product-badge.badge-new { background: #6a9a6a; }
    .product-badge.badge-premium { background: #8b6914; }
    .product-badge.badge-limited { background: #8b3a3a; }
    .product-card-cat { font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--grey-light); margin-bottom: 0.35rem; }
    .product-card-name { font-family: var(--serif); font-size: 1.15rem; font-weight: 400; line-height: 1.35; margin-bottom: 0.4rem; }
    .product-card-price { font-size: 0.95rem; font-weight: 400; color: var(--accent); }
    .product-card-rrp { font-size: 0.78rem; color: var(--grey-light); text-decoration: line-through; margin-left: 0.4rem; }

    /* RESPONSIVE */
    @media (max-width: 768px) {
      nav { padding: 0 1.5rem; }
      .nav-links { display: none; position: fixed; top: var(--nav-height); left: 0; right: 0; background: var(--white); flex-direction: column; padding: 2rem 1.5rem; gap: 1.5rem; border-bottom: 1px solid var(--sand); }
      .nav-links.open { display: flex; }
      .nav-toggle { display: block; }
      #ysp-lang-switcher { border-left: none; padding-left: 0; margin-left: 0; }
      footer { padding: 3rem 1.5rem 1.5rem; }
      .footer-top { grid-template-columns: 1fr; gap: 2rem; }
      .footer-bottom { flex-direction: column; gap: 0.5rem; }
    }

    /* MAILING LIST POPUP */
    #ysp-popup-overlay {
      position: fixed; inset: 0; background: rgba(26,25,22,0.7);
      z-index: 9990; display: flex; align-items: center; justify-content: center;
      opacity: 0; transition: opacity 0.4s ease; pointer-events: none;
    }
    #ysp-popup-overlay.visible { opacity: 1; pointer-events: all; }
    #ysp-popup {
      background: var(--white); max-width: 480px; width: calc(100% - 3rem);
      padding: 3rem; position: relative; text-align: center;
      transform: translateY(20px); transition: transform 0.4s ease;
    }
    #ysp-popup-overlay.visible #ysp-popup { transform: translateY(0); }
    .popup-close {
      position: absolute; top: 1rem; right: 1rem;
      background: none; border: none; font-size: 1.2rem;
      color: var(--grey); cursor: pointer; transition: color 0.2s;
    }
    .popup-close:hover { color: var(--black); }
    .popup-label { font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.8rem; }
    .popup-title { font-family: var(--serif); font-size: 2rem; font-weight: 300; margin-bottom: 0.8rem; line-height: 1.2; }
    .popup-sub { font-size: 0.88rem; color: var(--grey); line-height: 1.7; margin-bottom: 1.8rem; }
    .popup-discount { font-family: var(--serif); font-size: 3rem; font-weight: 300; color: var(--accent); margin-bottom: 0.5rem; line-height: 1; }
    .popup-form { display: flex; gap: 0; margin-bottom: 0.8rem; }
    .popup-input {
      flex: 1; padding: 0.85rem 1rem; border: 1px solid var(--sand);
      background: var(--white); font-family: var(--sans); font-size: 0.88rem;
      color: var(--black); outline: none; transition: border-color 0.2s;
    }
    .popup-input:focus { border-color: var(--accent); }
    .popup-btn {
      padding: 0.85rem 1.5rem; background: var(--black); color: var(--white);
      border: none; font-family: var(--sans); font-size: 0.72rem;
      letter-spacing: 0.12em; text-transform: uppercase; cursor: pointer;
      transition: background 0.2s; white-space: nowrap;
    }
    .popup-btn:hover { background: var(--accent); }
    .popup-terms { font-size: 0.68rem; color: var(--grey-light); }
    .popup-success { font-size: 0.9rem; color: var(--accent); padding: 1rem 0; display: none; }
  </style>

  {{ head_extra | safe }}

</head>
<body>

  <!-- FREE SHIPPING BANNER -->
  <div id="shipping-banner">
    <div class="banner-inner">
      <span class="banner-text">🚚 Free shipping on orders over €50 across Europe &nbsp;·&nbsp; 📍 Free next-day delivery in Loulé</span>
      <button class="banner-close" onclick="this.parentElement.parentElement.style.display='none'" aria-label="Close">✕</button>
    </div>
  </div>

  <nav id="main-nav">
    <a href="/" class="nav-logo">
      <div>
        <span class="nav-logo-text">YSP</span>
        <span class="nav-logo-sub">Collective</span>
      </div>
    </a>
    <button class="nav-toggle" aria-label="Menu" onclick="this.classList.toggle('open'); document.querySelector('.nav-links').classList.toggle('open');">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links">
      <li><a href="/#featured-fragrances" data-i18n="nav_fragrances">Fragrances</a></li>
      <li><a href="/#featured-beauty" data-i18n="nav_beauty">Beauty</a></li>
      <li><a href="/#brands" data-i18n="nav_brands">Brands</a></li>
      <li><a href="/#philosophy" data-i18n="nav_about">About</a></li>
      <li><a href="/#faq" data-i18n="nav_faq">FAQ</a></li>
      <li><a href="/#contact" data-i18n="nav_contact">Contact</a></li>
      <li><a href="/#contact" class="nav-cta" data-i18n="nav_enquire">Enquire</a></li>
      <li><a href="https://wa.me/351000000000" class="nav-whatsapp" target="_blank" rel="noopener" aria-label="WhatsApp">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      </a></li>
      <li id="ysp-lang-switcher"></li>
    </ul>
  </nav>

  {{ content | safe }}

  <footer>
    <div class="footer-top">
      <div class="footer-brand">
        <div>
          <span class="footer-logo-text">YSP</span>
          <span class="footer-logo-sub">Collective</span>
        </div>
        <p data-i18n="footer_desc">Curated beauty, fragrance and lifestyle products. Sourced from authorised distributors, delivered across Europe.</p>
      </div>
      <div class="footer-col">
        <h4 data-i18n="footer_shop">Shop</h4>
        <a href="/#featured-fragrances" data-i18n="nav_fragrances">Fragrances</a>
        <a href="/#featured-beauty" data-i18n="nav_beauty">Beauty &amp; Skincare</a>
        <a href="/#brands" data-i18n="nav_brands">Our Brands</a>
      </div>
      <div class="footer-col">
        <h4 data-i18n="footer_company">Company</h4>
        <a href="/#philosophy" data-i18n="footer_about">About Us</a>
        <a href="/#faq" data-i18n="nav_faq">FAQ</a>
        <a href="/#contact" data-i18n="nav_contact">Contact</a>
      </div>
      <div class="footer-col">
        <h4 data-i18n="footer_find">Also Find Us</h4>
        <a href="https://www.amazon.co.uk/s?me=A3M7XDMHQD6V9L" target="_blank" rel="noopener">Amazon EU</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 YSP Collective. <span data-i18n="footer_rights">All rights reserved.</span></span>
      <span>Portugal, European Union</span>
      <a href="https://www.livroreclamacoes.pt/Inicio/" target="_blank" rel="noopener" style="color:rgba(255,255,255,0.3);font-size:0.72rem;text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='rgba(255,255,255,0.6)'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">📋 Livro de Reclamações</a>
    </div>
  </footer>

  <!-- MAILING LIST POPUP -->
  <div id="ysp-popup-overlay">
    <div id="ysp-popup">
      <button class="popup-close" onclick="closePopup()" aria-label="Close">✕</button>
      <div class="popup-label">Welcome to YSP Collective</div>
      <div class="popup-discount">10% OFF</div>
      <h2 class="popup-title">Your first order</h2>
      <p class="popup-sub">Join our list for exclusive offers, new arrivals and fragrance recommendations. Get 10% off your first order.</p>
      <div class="popup-form">
        <input type="email" class="popup-input" id="popup-email" placeholder="your@email.com" onkeydown="if(event.key==='Enter')submitPopup()">
        <button class="popup-btn" onclick="submitPopup()">Get 10% Off</button>
      </div>
      <p class="popup-success" id="popup-success">✓ Thank you! Check your email for your discount code.</p>
      <p class="popup-terms">No spam. Unsubscribe anytime.</p>
    </div>
  </div>

  <script src="/ysp-translations.js"></script>
  <script src="/ysp-lang.js"></script>
  <script src="/ysp-products-data.js"></script>
  <script src="/ysp-config.js"></script>
  <script src="/ysp-chat.js"></script>

  <script>
    const nav = document.getElementById('main-nav');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 60);
    }, { passive: true });

    const reveals = document.querySelectorAll('.reveal');
    const ro = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => entry.target.classList.add('visible'), i * 60);
          ro.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08 });
    reveals.forEach(el => ro.observe(el));

    // Mailing list popup
    function closePopup() {
      document.getElementById('ysp-popup-overlay').classList.remove('visible');
      try { localStorage.setItem('ysp_popup_seen', '1'); } catch(e) {}
    }

    async function submitPopup() {
      const email = document.getElementById('popup-email').value;
      if (!email || !email.includes('@')) return;
      const btn = document.querySelector('.popup-btn');
      btn.textContent = '...';
      btn.disabled = true;
      try {
        const lang = window.YSP_LANG ? window.YSP_LANG.get() : 'en';
        const res = await fetch('https://ysp-ai-proxy.rapid-shadow-439d.workers.dev/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, lang })
        });
        const data = await res.json();
        if (data.success) {
          document.getElementById('popup-success').style.display = 'block';
          document.querySelector('.popup-form').style.display = 'none';
          try { localStorage.setItem('ysp_popup_seen', '1'); } catch(e) {}
          setTimeout(() => closePopup(), 3000);
        } else {
          btn.textContent = 'Get 10% Off';
          btn.disabled = false;
          alert('Something went wrong — please try again.');
        }
      } catch(e) {
        btn.textContent = 'Get 10% Off';
        btn.disabled = false;
      }
    }

    // Show popup after 8 seconds if not seen before
    try {
      if (!localStorage.getItem('ysp_popup_seen')) {
        setTimeout(() => {
          document.getElementById('ysp-popup-overlay').classList.add('visible');
        }, 8000);
      }
    } catch(e) {}

    // Close on overlay click
    document.getElementById('ysp-popup-overlay').addEventListener('click', function(e) {
      if (e.target === this) closePopup();
    });

    window.addEventListener('DOMContentLoaded', () => {
      const subject = sessionStorage.getItem('enquiry_subject');
      if (subject) {
        const input = document.querySelector('#contact input[name="subject"]');
        if (input) input.value = subject;
        sessionStorage.removeItem('enquiry_subject');
      }
    });
  </script>

  {{ body_extra | safe }}
  <script src="/ysp-cart.js"></script>
  <script src="/ysp-image-fix.js"></script>

</body>
</html>
