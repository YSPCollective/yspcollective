<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{ title or 'YSP Collective — Beauty, Fragrance & Curated Lifestyle' }}</title>
  <meta name="description" content="{{ description or 'YSP Collective — Curated beauty, skincare, fragrance and premium lifestyle products. Sourced with care, delivered across Europe from Portugal.' }}">
  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png">
  <meta name="theme-color" content="#1a1916">
  <link rel="canonical" href="{{ canonical or 'https://yspcollective.com/' }}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Outfit:wght@200;300;400;500&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #1a1916;
      --white: #faf8f5;
      --cream: #f3efe8;
      --sand: #e6dfd4;
      --grey: #8a847a;
      --grey-light: #b5afa5;
      --accent: #9c7b56;
      --accent-light: #c8a87a;
      --serif: 'Playfair Display', Georgia, serif;
      --sans: 'Outfit', -apple-system, sans-serif;
      --nav-height: 80px;
      --transition: cubic-bezier(0.4, 0, 0.2, 1);
    }

    html { scroll-behavior: smooth; }
    body { background: var(--white); color: var(--black); font-family: var(--sans); font-weight: 300; overflow-x: hidden; -webkit-font-smoothing: antialiased; }
    a { color: inherit; }

    /* ── ANNOUNCEMENT BAR ── */
    #announcement-bar {
      background: var(--black);
      color: rgba(255,255,255,0.85);
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-align: center;
      padding: 0.6rem 3.5rem;
      position: relative;
      z-index: 1001;
    }
    .announcement-inner { display: flex; align-items: center; justify-content: center; gap: 1rem; max-width: 900px; margin: 0 auto; }
    .announcement-text { flex: 1; text-align: center; }
    .announcement-close { background: none; border: none; color: rgba(255,255,255,0.4); cursor: pointer; font-size: 0.8rem; padding: 0; line-height: 1; transition: color 0.2s; flex-shrink: 0; }
    .announcement-close:hover { color: rgba(255,255,255,0.8); }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 1000;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 3.5rem;
      height: var(--nav-height);
      background: rgba(250, 248, 245, 0.94);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(0,0,0,0.04);
      transition: height 0.4s var(--transition), box-shadow 0.4s var(--transition);
    }
    nav.scrolled { height: 64px; box-shadow: 0 1px 20px rgba(0,0,0,0.05); }

    .nav-logo { text-decoration: none; display: flex; align-items: center; }
    .nav-logo-text { font-family: var(--serif); font-size: 1.6rem; font-weight: 300; letter-spacing: 0.06em; color: var(--black); transition: font-size 0.4s var(--transition); }
    nav.scrolled .nav-logo-text { font-size: 1.3rem; }
    .nav-logo-sub { font-family: var(--sans); font-size: 0.55rem; letter-spacing: 0.35em; text-transform: uppercase; color: var(--grey); display: block; margin-top: -2px; }

    .nav-links { list-style: none; display: none; }
    .nav-links a { font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--grey); text-decoration: none; transition: color 0.25s; font-weight: 400; }
    .nav-links a:hover { color: var(--accent); }
    .nav-cta { padding: 0.55rem 1.5rem; background: var(--accent); color: var(--white) !important; font-size: 0.7rem !important; transition: background 0.25s, transform 0.25s; }
    .nav-cta:hover { background: var(--black) !important; transform: translateY(-1px); }

    /* ── NAV DROPDOWNS (desktop) ── */
    .nav-dropdown-wrap { position: relative; }
    .nav-dropdown-trigger {
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--grey);
      background: none;
      border: none;
      cursor: pointer;
      font-family: var(--sans);
      font-weight: 400;
      display: flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0;
      transition: color 0.25s;
    }
    .nav-dropdown-trigger:hover { color: var(--accent); }
    .nav-chevron { font-size: 0.5rem; opacity: 0.6; transition: transform 0.2s; }
    .nav-dropdown-wrap.open .nav-chevron { transform: rotate(180deg); }

    .nav-dropdown {
      display: none;
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      background: var(--white);
      border: 1px solid var(--sand);
      box-shadow: 0 12px 40px rgba(0,0,0,0.1);
      z-index: 2000;
      min-width: 600px;
      padding-top: 1rem;
    }
    .nav-dropdown-inner {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 0;
      padding: 1.5rem 2rem 2rem;
    }
    .nav-dropdown.beauty-dropdown { min-width: 340px; }
    .nav-dropdown.beauty-dropdown .nav-dropdown-inner { grid-template-columns: 1fr 1fr; }
    .nav-dropdown-wrap.open .nav-dropdown { display: block; }

    .nav-dropdown-col h4 {
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 400;
      margin-bottom: 0.8rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--sand);
    }
    .nav-dropdown-col a {
      display: block;
      font-size: 0.78rem;
      letter-spacing: 0.04em;
      text-transform: none !important;
      color: var(--grey) !important;
      text-decoration: none;
      padding: 0.3rem 0;
      transition: color 0.2s;
      font-weight: 300;
    }
    .nav-dropdown-col a:hover { color: var(--accent) !important; }

    /* ── HAMBURGER ── */
    .nav-toggle { display: none; background: none; border: none; cursor: pointer; width: 28px; height: 20px; position: relative; flex-shrink: 0; }
    .nav-toggle span { display: block; width: 100%; height: 1.5px; background: var(--black); position: absolute; left: 0; transition: all 0.3s; }
    .nav-toggle span:nth-child(1) { top: 0; }
    .nav-toggle span:nth-child(2) { top: 50%; transform: translateY(-50%); }
    .nav-toggle span:nth-child(3) { bottom: 0; }
    .nav-toggle.open span:nth-child(1) { top: 50%; transform: translateY(-50%) rotate(45deg); }
    .nav-toggle.open span:nth-child(2) { opacity: 0; }
    .nav-toggle.open span:nth-child(3) { bottom: 50%; transform: translateY(50%) rotate(-45deg); }

    /* ── FOOTER ── */
    footer { padding: 4rem 3.5rem 2rem; background: var(--black); color: rgba(255,255,255,0.4); }
    .footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; margin-bottom: 3rem; }
    .footer-brand .nav-logo-text { color: var(--white); font-size: 1.4rem; }
    .footer-brand .nav-logo-sub { color: rgba(255,255,255,0.3); }
    .footer-brand p { font-size: 0.85rem; line-height: 1.7; margin-top: 1rem; color: rgba(255,255,255,0.35); }
    .footer-social { display: flex; gap: 0.8rem; margin-top: 1.5rem; align-items: center; }
    .footer-social a { display: flex; align-items: center; justify-content: center; width: 34px; height: 34px; border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.4); transition: all 0.25s; }
    .footer-social a:hover { border-color: var(--accent-light); color: var(--accent-light); transform: translateY(-2px); }
    .footer-social svg { width: 15px; height: 15px; fill: currentColor; }
    .footer-col h4 { font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.55); margin-bottom: 1.2rem; font-weight: 400; }
    .footer-col a { display: block; font-size: 0.85rem; color: rgba(255,255,255,0.35); text-decoration: none; margin-bottom: 0.6rem; transition: color 0.25s; }
    .footer-col a:hover { color: var(--accent-light); }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,0.06); padding-top: 1.5rem; display: flex; justify-content: space-between; align-items: center; font-size: 0.72rem; flex-wrap: wrap; gap: 0.5rem; }
    .footer-bottom-links { display: flex; gap: 1.5rem; }
    .footer-bottom-links a { color: rgba(255,255,255,0.3); text-decoration: none; transition: color 0.25s; }
    .footer-bottom-links a:hover { color: var(--accent-light); }

    /* ── REVEAL ── */
    .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.8s var(--transition), transform 0.8s var(--transition); }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* ── SECTION UTILITIES ── */
    .section-label { font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.2rem; font-weight: 400; }
    .section-title { font-family: var(--serif); font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 300; line-height: 1.2; margin-bottom: 1.5rem; }
    .section-desc { font-size: 0.95rem; line-height: 1.8; color: var(--grey); max-width: 520px; }

    /* ── RESPONSIVE ── */

    /* ── MOBILE MENU OVERLAY (separate from nav) ── */
    #mobile-menu {
      display: none;
      position: fixed;
      inset: 0;
      background: var(--white);
      z-index: 99999;
      flex-direction: column;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
    }
    #mobile-menu.open { display: flex; }

    .mobile-menu-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.4rem 1.5rem;
      border-bottom: 2px solid var(--sand);
      flex-shrink: 0;
      position: sticky;
      top: 0;
      background: var(--white);
      z-index: 2;
    }
    .mobile-menu-logo {
      font-family: var(--serif);
      font-size: 1.5rem;
      font-weight: 300;
      color: var(--black);
    }
    #mobile-menu-close {
      background: none;
      border: 1px solid var(--sand);
      width: 36px;
      height: 36px;
      font-size: 1.1rem;
      cursor: pointer;
      color: var(--grey);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
    }
    #mobile-menu-close:hover { background: var(--black); color: var(--white); border-color: var(--black); }

    .mobile-menu-links {
      list-style: none;
      flex: 1;
      padding: 0;
    }
    .mobile-menu-links > li {
      border-bottom: 1px solid var(--sand);
    }
    .mobile-menu-links > li > a {
      display: block;
      padding: 1rem 1.5rem;
      font-size: 0.9rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--black);
      text-decoration: none;
      font-weight: 400;
    }
    .mobile-dd-trigger {
      width: 100%;
      padding: 1rem 1.5rem;
      font-size: 0.9rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--black);
      background: none;
      border: none;
      cursor: pointer;
      font-family: var(--sans);
      font-weight: 400;
      display: flex;
      justify-content: space-between;
      align-items: center;
      text-align: left;
    }
    .mobile-chevron { font-size: 0.6rem; opacity: 0.5; transition: transform 0.25s; }
    .mobile-dd-wrap.open .mobile-chevron { transform: rotate(180deg); }

    .mobile-dd-panel {
      display: none;
      background: var(--cream);
      padding: 0.5rem 1.5rem 1rem;
      border-top: 1px solid var(--sand);
    }
    .mobile-dd-wrap.open .mobile-dd-panel { display: block; }

    .mobile-dd-section { margin-bottom: 0.8rem; }
    .mobile-dd-section h4 {
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 400;
      padding: 0.6rem 0 0.4rem;
      border-bottom: 1px solid var(--sand);
      margin-bottom: 0.3rem;
    }
    .mobile-dd-section a {
      display: block;
      padding: 0.45rem 0;
      font-size: 0.88rem;
      color: var(--grey);
      text-decoration: none;
      letter-spacing: 0.02em;
    }
    .mobile-dd-section a:hover { color: var(--accent); }

    .mobile-cta {
      display: block;
      margin: 1rem 1.5rem;
      padding: 0.9rem;
      background: var(--accent);
      color: var(--white) !important;
      text-align: center;
      font-size: 0.78rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      text-decoration: none;
      font-weight: 400;
    }

    @media (min-width: 769px) {
      .nav-links { display: flex; gap: 2rem; align-items: center; }
    }

    @media (max-width: 1024px) {
      .footer-top { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 768px) {
      nav { padding: 0 1.5rem; }
      .nav-toggle { display: block; }
      .nav-links { display: none !important; } /* Hidden on mobile — use #mobile-menu instead */
      #announcement-bar { padding: 0.6rem 2.5rem 0.6rem 1rem; font-size: 0.68rem; }
      footer { padding: 3rem 1.5rem 1.5rem; }
      .footer-top { grid-template-columns: 1fr; gap: 2rem; }
      .footer-bottom { flex-direction: column; gap: 0.8rem; }
      .footer-bottom-links { flex-wrap: wrap; gap: 1rem; }
    }
  </style>

  {{ head_extra | safe }}
</head>
