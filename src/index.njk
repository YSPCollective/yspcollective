---
layout: base.njk
title: "YSP Collective — Beauty, Fragrance & Curated Lifestyle"
description: "Curated beauty, skincare, fragrance and premium lifestyle products. Sourced with care, delivered across Europe from Portugal."
canonical: "https://yspcollective.com/"
---

<style>
  /* HERO */
  #hero { position: relative; height: 100vh; min-height: 600px; overflow: hidden; }
  .hero-slide { position: absolute; inset: 0; opacity: 0; transition: opacity 1.2s cubic-bezier(0.4,0,0.2,1); z-index: 1; }
  .hero-slide.active { opacity: 1; z-index: 2; }
  .hero-slide-bg { position: absolute; inset: 0; background: var(--sand); background-size: cover; background-position: center; transform: scale(1.05); transition: transform 8s ease-out; }
  .hero-slide.active .hero-slide-bg { transform: scale(1); }
  .hero-slide:nth-child(1) .hero-slide-bg { background: linear-gradient(135deg, #e6dfd4 0%, #d4c9b8 100%); }
  .hero-slide:nth-child(2) .hero-slide-bg { background: linear-gradient(135deg, #d4c4b0 0%, #c8b8a4 100%); }
  .hero-slide:nth-child(3) .hero-slide-bg { background: linear-gradient(135deg, #c8bfb2 0%, #bab0a0 100%); }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to right, rgba(26,25,22,0.55) 0%, rgba(26,25,22,0.2) 50%, transparent 100%); z-index: 1; }
  .hero-content { position: absolute; inset: 0; z-index: 2; display: flex; flex-direction: column; justify-content: center; padding: 0 5rem; padding-top: var(--nav-height); }
  .hero-tag { font-size: 0.68rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--accent-light); margin-bottom: 1.5rem; opacity: 0; transform: translateY(16px); transition: all 0.8s 0.3s; }
  .hero-slide.active .hero-tag { opacity: 1; transform: translateY(0); }
  .hero-title { font-family: var(--serif); font-size: clamp(2.8rem,5.5vw,5rem); font-weight: 300; line-height: 1.12; color: var(--white); max-width: 620px; margin-bottom: 1.5rem; opacity: 0; transform: translateY(24px); transition: all 0.8s 0.5s; }
  .hero-slide.active .hero-title { opacity: 1; transform: translateY(0); }
  .hero-title em { font-style: italic; color: var(--accent-light); }
  .hero-sub { font-size: 1rem; line-height: 1.75; color: rgba(255,255,255,0.7); max-width: 420px; margin-bottom: 2.5rem; opacity: 0; transform: translateY(20px); transition: all 0.8s 0.7s; }
  .hero-slide.active .hero-sub { opacity: 1; transform: translateY(0); }
  .hero-cta-group { display: flex; gap: 1rem; opacity: 0; transform: translateY(16px); transition: all 0.8s 0.9s; }
  .hero-slide.active .hero-cta-group { opacity: 1; transform: translateY(0); }
  .btn-hero { display: inline-block; padding: 0.85rem 2rem; font-family: var(--sans); font-size: 0.72rem; font-weight: 400; letter-spacing: 0.14em; text-transform: uppercase; text-decoration: none; transition: all 0.3s; }
  .btn-hero-primary { background: var(--accent); color: var(--white); }
  .btn-hero-primary:hover { background: var(--white); color: var(--black); }
  .btn-hero-secondary { border: 1px solid rgba(255,255,255,0.4); color: var(--white); }
  .btn-hero-secondary:hover { background: rgba(255,255,255,0.1); border-color: var(--white); }
  .hero-indicators { position: absolute; bottom: 3rem; left: 5rem; z-index: 10; display: flex; gap: 0.8rem; }
  .hero-dot { width: 32px; height: 2px; background: rgba(255,255,255,0.3); border: none; cursor: pointer; transition: all 0.4s; padding: 0; }
  .hero-dot.active { background: var(--white); width: 48px; }
  .hero-progress { position: absolute; bottom: 0; left: 0; height: 3px; background: var(--accent-light); z-index: 10; transition: width 0.1s linear; }

  /* STATS */
  #intro-band { padding: 4rem 3.5rem; display: flex; justify-content: center; align-items: center; gap: 4rem; border-bottom: 1px solid var(--sand); flex-wrap: wrap; }
  .intro-stat { text-align: center; }
  .intro-stat .num { font-family: var(--serif); font-size: 2.4rem; font-weight: 300; color: var(--accent); display: block; margin-bottom: 0.3rem; }
  .intro-stat .label { font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--grey); }
  .intro-divider { width: 1px; height: 48px; background: var(--sand); }

  /* SEARCH */
  #product-search { padding: 4rem 3.5rem; background: var(--black); }
  .search-inner { max-width: 900px; margin: 0 auto; text-align: center; }
  .search-inner .section-label { color: var(--accent-light); }
  .search-inner .section-title { color: var(--white); margin-bottom: 2rem; }
  .search-bar { display: flex; gap: 0; margin-bottom: 1.5rem; }
  #search-input { flex: 1; padding: 1rem 1.5rem; border: none; background: rgba(255,255,255,0.08); color: var(--white); font-family: var(--sans); font-size: 0.9rem; font-weight: 300; outline: none; transition: background 0.3s; }
  #search-input::placeholder { color: rgba(255,255,255,0.3); }
  #search-input:focus { background: rgba(255,255,255,0.12); }
  .search-filters { display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: center; }
  .filter-chip { padding: 0.4rem 1rem; border: 1px solid rgba(255,255,255,0.15); background: transparent; color: rgba(255,255,255,0.5); font-family: var(--sans); font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; transition: all 0.2s; }
  .filter-chip:hover, .filter-chip.active { background: var(--accent); border-color: var(--accent); color: var(--white); }
  #search-results { margin-top: 2rem; display: none; }
  #search-results.visible { display: block; }
  .search-results-wrapper { overflow-x: auto; padding-bottom: 1rem; margin-top: 1.5rem; }
  .search-results-wrapper::-webkit-scrollbar { height: 4px; }
  .search-results-wrapper::-webkit-scrollbar-track { background: rgba(255,255,255,0.05); }
  .search-results-wrapper::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 2px; }
  .search-results-grid { display: flex; gap: 1.5rem; width: max-content; }
  .search-results-grid .search-product-card { width: 220px; flex-shrink: 0; }
  .search-result-count { font-size: 0.75rem; color: rgba(255,255,255,0.4); letter-spacing: 0.1em; text-transform: uppercase; margin-top: 1rem; }
  .no-results { color: rgba(255,255,255,0.4); font-size: 0.9rem; padding: 2rem; }

  /* FEATURED SECTIONS */
  .featured-section { padding: 6rem 3.5rem; }
  .featured-section.bg-cream { background: var(--cream); }
  .featured-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem; flex-wrap: wrap; gap: 1rem; }
  .products-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1.8rem; }

  /* PHILOSOPHY */
  #philosophy { padding: 7rem 3.5rem; background: var(--cream); display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .philosophy-image { aspect-ratio: 4/5; background: var(--sand); position: relative; overflow: hidden; }
  .philosophy-image img { width: 100%; height: 100%; object-fit: cover; }
  .philosophy-text p { font-size: 0.95rem; line-height: 1.85; color: var(--grey); margin-bottom: 1.2rem; }
  .philosophy-values { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 2.5rem; }
  .pv-item { padding: 1.5rem; border: 1px solid var(--sand); background: var(--white); transition: border-color 0.3s, transform 0.3s; }
  .pv-item:hover { border-color: var(--accent); transform: translateY(-2px); }
  .pv-num { font-family: var(--serif); font-size: 1.6rem; color: var(--accent); font-weight: 300; margin-bottom: 0.4rem; }
  .pv-title { font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 400; margin-bottom: 0.3rem; }
  .pv-desc { font-size: 0.82rem; color: var(--grey); line-height: 1.6; }

  /* CATEGORIES */
  #categories { padding: 7rem 3.5rem; }
  .categories-header { text-align: center; margin-bottom: 3.5rem; }
  .categories-header .section-desc { margin: 0 auto; }
  .categories-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
  .category-card { position: relative; aspect-ratio: 3/4; overflow: hidden; background: var(--cream); text-decoration: none; color: inherit; display: block; }
  .category-card-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(26,25,22,0.65) 0%, transparent 60%); z-index: 1; transition: background 0.4s; }
  .category-card:hover .category-card-overlay { background: linear-gradient(to top, rgba(26,25,22,0.75) 0%, rgba(26,25,22,0.1) 60%); }
  .category-card img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .category-card-content { position: absolute; bottom: 0; left: 0; right: 0; padding: 2rem; z-index: 2; }
  .category-card-name { font-family: var(--serif); font-size: 1.8rem; font-weight: 300; color: var(--white); margin-bottom: 0.4rem; }
  .category-card-count { font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.6); }

  /* BRANDS */
  #brands { padding: 5rem 3.5rem; background: var(--black); color: var(--white); text-align: center; }
  .brands-grid { display: flex; justify-content: center; gap: 1.5rem; flex-wrap: wrap; margin-top: 3rem; }
  .brand-item { border: 1px solid rgba(255,255,255,0.08); padding: 1.8rem 2.2rem; min-width: 140px; transition: border-color 0.3s, transform 0.3s; cursor: default; }
  .brand-item:hover { border-color: var(--accent); transform: translateY(-2px); }
  .brand-name { font-family: var(--serif); font-size: 1.3rem; font-weight: 400; color: var(--white); margin-bottom: 0.3rem; }
  .brand-origin { font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.35); }

  /* TESTIMONIALS */
  #testimonials { padding: 7rem 3.5rem; background: var(--cream); text-align: center; }
  .testimonial-track { max-width: 640px; margin: 0 auto; }
  .testimonial-item { display: none; }
  .testimonial-item.active { display: block; }
  .testimonial-quote { font-family: var(--serif); font-size: 1.5rem; font-weight: 300; font-style: italic; line-height: 1.6; color: var(--black); margin-bottom: 1.5rem; }
  .testimonial-author { font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--grey); }
  .testimonial-dots { display: flex; justify-content: center; gap: 0.6rem; margin-top: 2rem; }
  .testimonial-dot { width: 8px; height: 8px; border-radius: 50%; border: 1px solid var(--grey-light); background: transparent; cursor: pointer; padding: 0; transition: all 0.3s; }
  .testimonial-dot.active { background: var(--accent); border-color: var(--accent); }

  /* FAQ */
  #faq { padding: 7rem 3.5rem; max-width: 820px; margin: 0 auto; }
  .faq-header { text-align: center; margin-bottom: 3rem; }
  .faq-item { border-top: 1px solid var(--sand); padding: 1.5rem 0; }
  .faq-item:last-child { border-bottom: 1px solid var(--sand); }
  .faq-question { display: flex; justify-content: space-between; align-items: center; cursor: pointer; font-size: 0.95rem; font-weight: 400; user-select: none; transition: color 0.25s; }
  .faq-question:hover { color: var(--accent); }
  .faq-icon { font-size: 1.2rem; color: var(--accent); transition: transform 0.3s; flex-shrink: 0; margin-left: 1rem; }
  .faq-answer { font-size: 0.88rem; color: var(--grey); line-height: 1.8; max-height: 0; overflow: hidden; transition: max-height 0.4s ease, padding 0.3s ease; }
  .faq-item.open .faq-answer { max-height: 400px; padding-top: 1rem; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  /* CONTACT */
  #contact { padding: 7rem 3.5rem; background: var(--cream); display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
  .contact-info p { font-size: 0.95rem; color: var(--grey); line-height: 1.8; margin-bottom: 2.5rem; }
  .contact-detail { display: flex; flex-direction: column; gap: 1rem; }
  .contact-line { display: flex; gap: 1rem; align-items: center; font-size: 0.85rem; color: var(--grey); }
  .contact-line-icon { color: var(--accent); font-family: var(--serif); font-size: 1.1rem; width: 1.5rem; flex-shrink: 0; }
  .contact-form { display: flex; flex-direction: column; gap: 1.2rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .form-label { font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--grey); font-weight: 400; }
  .form-input, .form-textarea { background: transparent; border: none; border-bottom: 1px solid var(--sand); padding: 0.75rem 0; color: var(--black); font-family: var(--sans); font-size: 0.9rem; font-weight: 300; transition: border-color 0.3s; outline: none; resize: none; }
  .form-input:focus, .form-textarea:focus { border-color: var(--accent); }
  .form-textarea { min-height: 100px; }
  .form-input::placeholder, .form-textarea::placeholder { color: var(--grey-light); }
  .btn-submit { margin-top: 0.5rem; padding: 0.9rem 2.2rem; background: var(--accent); color: var(--white); border: none; font-family: var(--sans); font-size: 0.72rem; font-weight: 400; letter-spacing: 0.14em; text-transform: uppercase; cursor: pointer; align-self: flex-start; transition: background 0.25s, transform 0.25s; }
  .btn-submit:hover { background: var(--black); transform: translateY(-1px); }
  .form-status { font-size: 0.82rem; margin-top: 0.5rem; display: none; }

  /* SEARCH RESULT CARDS */
  .search-product-card { text-decoration: none; color: var(--white); display: block; transition: transform 0.3s; }
  .search-product-card:hover { transform: translateY(-3px); }
  .search-card-img { aspect-ratio: 3/4; background: rgba(255,255,255,0.06); overflow: hidden; margin-bottom: 0.8rem; }
  .search-card-img img { width: 100%; height: 100%; object-fit: cover; }
  .search-card-name { font-family: var(--serif); font-size: 1rem; margin-bottom: 0.3rem; line-height: 1.3; }
  .search-card-meta { font-size: 0.7rem; color: rgba(255,255,255,0.4); margin-bottom: 0.3rem; letter-spacing: 0.08em; text-transform: uppercase; }
  .search-card-price { font-size: 0.95rem; color: var(--accent-light); }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .products-grid { grid-template-columns: repeat(2,1fr); }
    #philosophy { grid-template-columns: 1fr; }
    .philosophy-image { max-height: 400px; }
    .search-results-grid { grid-template-columns: repeat(2,1fr); }
  }
  @media (max-width: 768px) {
    .hero-content { padding: 0 1.5rem; padding-top: var(--nav-height); }
    .hero-indicators { left: 1.5rem; }
    #intro-band { padding: 3rem 1.5rem; gap: 2rem; }
    .intro-divider { display: none; }
    #product-search { padding: 4rem 1.5rem; }
    .featured-section { padding: 4rem 1.5rem; }
    .products-grid { grid-template-columns: 1fr 1fr; gap: 1rem; }
    #philosophy { padding: 5rem 1.5rem; gap: 3rem; }
    .philosophy-values { grid-template-columns: 1fr; }
    #categories { padding: 5rem 1.5rem; }
    .categories-grid { grid-template-columns: 1fr; }
    #brands { padding: 4rem 1.5rem; }
    #testimonials { padding: 5rem 1.5rem; }
    #faq { padding: 5rem 1.5rem; }
    #contact { grid-template-columns: 1fr; gap: 3rem; padding: 5rem 1.5rem; }
    .search-results-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .products-grid { grid-template-columns: 1fr; }
    .search-results-grid { grid-template-columns: 1fr; }
  }
</style>

<!-- HERO -->
<section id="hero">
  <div class="hero-slide active">
    <div class="hero-slide-bg" style="background: url('/images/hero-1.jpg') center/cover no-repeat;"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="hero-tag" data-i18n="hero_1_tag">Beauty · Skincare · Fragrance</p>
      <h1 class="hero-title" data-i18n="hero_1_title" data-i18n-html="true">Curated beauty,<br><em>elevated</em> living.</h1>
      <p class="hero-sub" data-i18n="hero_1_sub">Premium skincare, fragrance and beauty products — sourced from trusted brands, delivered across Europe.</p>
      <div class="hero-cta-group">
        <a href="#featured-fragrances" class="btn-hero btn-hero-primary" data-i18n="hero_1_cta1">Shop Fragrances</a>
        <a href="#philosophy" class="btn-hero btn-hero-secondary" data-i18n="hero_1_cta2">Our Story</a>
      </div>
    </div>
  </div>
  <div class="hero-slide">
    <div class="hero-slide-bg" style="background: url('/images/hero-2.png') center/cover no-repeat;"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="hero-tag" data-i18n="hero_2_tag">K-Beauty · SPF · Clean Skincare</p>
      <h1 class="hero-title" data-i18n="hero_2_title" data-i18n-html="true">The products<br>we <em>actually</em> use.</h1>
      <p class="hero-sub" data-i18n="hero_2_sub">Every item in our range is something we'd recommend to someone we know. No filler, no grey market — just products that work.</p>
      <div class="hero-cta-group">
        <a href="#featured-beauty" class="btn-hero btn-hero-primary" data-i18n="hero_2_cta1">Shop Beauty</a>
        <a href="#contact" class="btn-hero btn-hero-secondary" data-i18n="hero_2_cta2">Get in Touch</a>
      </div>
    </div>
  </div>
  <div class="hero-slide">
    <div class="hero-slide-bg" style="background: url('/images/hero-3.jpg') center/cover no-repeat;"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="hero-tag" data-i18n="hero_3_tag">Fragrance · Arabian Perfume · Niche Scents</p>
      <h1 class="hero-title" data-i18n="hero_3_title" data-i18n-html="true">Discover Arabian<br><em>fragrance.</em></h1>
      <p class="hero-sub" data-i18n="hero_3_sub">From Lattafa to Armaf — experience the scents taking Europe by storm. Rich, long-lasting compositions at a fraction of designer prices.</p>
      <div class="hero-cta-group">
        <a href="#featured-fragrances" class="btn-hero btn-hero-primary" data-i18n="hero_3_cta1">Explore Range</a>
        <a href="#contact" class="btn-hero btn-hero-secondary" data-i18n="hero_3_cta2">Wholesale</a>
      </div>
    </div>
  </div>
  <div class="hero-indicators">
    <button class="hero-dot active" data-slide="0" aria-label="Slide 1"></button>
    <button class="hero-dot" data-slide="1" aria-label="Slide 2"></button>
    <button class="hero-dot" data-slide="2" aria-label="Slide 3"></button>
  </div>
  <div class="hero-progress"></div>
</section>

<!-- STATS -->
<div id="intro-band">
  <div class="intro-stat reveal"><span class="num">500+</span><span class="label" data-i18n="stat_products">Products Delivered</span></div>
  <div class="intro-divider"></div>
  <div class="intro-stat reveal"><span class="num">98%</span><span class="label" data-i18n="stat_satisfaction">Customer Satisfaction</span></div>
  <div class="intro-divider"></div>
  <div class="intro-stat reveal"><span class="num">EU</span><span class="label" data-i18n="stat_based">Based &amp; Authorised</span></div>
  <div class="intro-divider"></div>
  <div class="intro-stat reveal"><span class="num">24h</span><span class="label" data-i18n="stat_dispatch">Average Dispatch</span></div>
</div>

<!-- SEARCH -->
<section id="product-search">
  <div class="search-inner reveal">
    <p class="section-label" data-i18n="search_label">Find Your Scent or Skincare</p>
    <h2 class="section-title" data-i18n="search_title">Search our range</h2>
    <div class="search-bar">
      <input type="text" id="search-input" data-i18n-placeholder="search_placeholder" placeholder="Search by name, brand, accord, or ingredient...">
    </div>
    <div class="search-filters">
      <button class="filter-chip active" data-filter="all" data-i18n="filter_all">All</button>
      <button class="filter-chip" data-filter="fragrance" data-i18n="filter_fragrance">Fragrance</button>
      <button class="filter-chip" data-filter="beauty" data-i18n="filter_beauty">Beauty</button>
      <button class="filter-chip" data-filter="vanilla" data-i18n="filter_vanilla">Vanilla</button>
      <button class="filter-chip" data-filter="oud" data-i18n="filter_oud">Oud</button>
      <button class="filter-chip" data-filter="floral" data-i18n="filter_floral">Floral</button>
      <button class="filter-chip" data-filter="fresh" data-i18n="filter_fresh">Fresh</button>
      <button class="filter-chip" data-filter="spicy" data-i18n="filter_spicy">Spicy</button>
      <button class="filter-chip" data-filter="gourmand" data-i18n="filter_gourmand">Gourmand</button>
      <button class="filter-chip" data-filter="woody" data-i18n="filter_woody">Woody</button>
    </div>
    <div id="search-results">
      <p class="no-results" id="no-results" data-i18n="no_results" style="display:none">No products found — try a different search.</p>
      <div class="search-results-wrapper"><div class="search-results-grid" id="search-results-grid"></div></div>
    </div>
  </div>
</section>

<!-- FEATURED FRAGRANCES -->
<section class="featured-section" id="featured-fragrances">
  <div class="featured-header reveal">
    <div>
      <p class="section-label" data-i18n="frag_label">Arabian &amp; Niche Fragrance</p>
      <h2 class="section-title" data-i18n="frag_title">Featured fragrances</h2>
    </div>
  </div>
  <div class="products-grid">
    {% set featuredFragrances = collections.fragrances | selectattr("data.featured") | list %}
    {% set displayFragrances = featuredFragrances if featuredFragrances.length else collections.fragrances %}
    {% for product in displayFragrances | limit(4) %}
    <a href="/products/{{ product.data.slug }}.html" class="product-card reveal">
      <div class="product-card-image">
        <img src="{{ product.data.image_main }}" alt="{{ product.data.name }}" loading="lazy">
        {% set badgeText = product.data.custom_badge or product.data.badge %}
        {% if badgeText %}
        <span class="product-badge {{ badgeText | badgeClass }}">{{ badgeText }}</span>
        {% endif %}
      </div>
      <div class="product-card-cat">{{ product.data.brand }} · {{ product.data.gender }}</div>
      <div class="product-card-name">{{ product.data.name }}</div>
      <div class="product-card-price">
        €{{ product.data.price }}
        {% if product.data.rrp %}<span class="product-card-rrp">€{{ product.data.rrp }}</span>{% endif %}
      </div>
    </a>
    {% endfor %}
  </div>
</section>

<!-- FEATURED BEAUTY -->
