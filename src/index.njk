<!-- ALL PRODUCTS DATA for search -->
<script>
const ALL_PRODUCTS = {{ collections.allProducts | jsonify | safe }};
</script>

<script>
  /* Hero carousel */
  const slides = document.querySelectorAll('.hero-slide');
  const heroDots = document.querySelectorAll('.hero-dot');
  const progressBar = document.querySelector('.hero-progress');
  let currentSlide = 0, slideTimer, progressTimer, progressWidth = 0;
  const slideInterval = 6000;

  function goToSlide(i) {
    slides[currentSlide].classList.remove('active');
    heroDots[currentSlide].classList.remove('active');
    currentSlide = i;
    slides[currentSlide].classList.add('active');
    heroDots[currentSlide].classList.add('active');
    progressWidth = 0;
  }
  function startCarousel() {
    clearInterval(slideTimer); clearInterval(progressTimer); progressWidth = 0;
    progressTimer = setInterval(() => { progressWidth += 100/(slideInterval/50); progressBar.style.width = Math.min(progressWidth,100)+'%'; }, 50);
    slideTimer = setInterval(() => { goToSlide((currentSlide+1)%slides.length); progressWidth=0; }, slideInterval);
  }
  heroDots.forEach(d => d.addEventListener('click', () => { goToSlide(parseInt(d.dataset.slide)); startCarousel(); }));
  startCarousel();

  /* FAQ */
  document.querySelectorAll('.faq-question').forEach(q => {
    q.addEventListener('click', () => {
      const item = q.parentElement;
      const wasOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
      if (!wasOpen) item.classList.add('open');
    });
  });

  /* Testimonials */
  const tItems = document.querySelectorAll('.testimonial-item');
  const tDots = document.querySelectorAll('.testimonial-dot');
  let currentT = 0;
  function showT(i) {
    tItems[currentT].classList.remove('active'); tDots[currentT].classList.remove('active');
    currentT = i;
    tItems[currentT].classList.add('active'); tDots[currentT].classList.add('active');
  }
  tDots.forEach(d => d.addEventListener('click', () => showT(parseInt(d.dataset.index))));
  setInterval(() => showT((currentT+1)%tItems.length), 8000);

  /* Contact form */
  function handleSubmit(e) {
    e.preventDefault();
    const form = e.target, btn = form.querySelector('.btn-submit'), status = document.getElementById('form-status');
    btn.textContent = 'Sending...'; btn.disabled = true;
    fetch('/', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body: new URLSearchParams(new FormData(form)).toString() })
    .then(r => {
      if (r.ok) {
        btn.textContent = 'Message Sent ✓'; btn.style.background = '#7a9a6a';
        status.textContent = "Thank you — we'll be in touch shortly."; status.style.color='#7a9a6a'; status.style.display='block';
        setTimeout(() => { btn.textContent='Send Message'; btn.style.background=''; btn.disabled=false; status.style.display='none'; form.reset(); }, 4000);
      } else throw new Error();
    }).catch(() => {
      btn.textContent='Send Message'; btn.disabled=false;
      status.textContent='Something went wrong — please email info@yspcollective.com'; status.style.color='#b5564e'; status.style.display='block';
    });
  }

  /* Search */
  const searchInput = document.getElementById('search-input');
  const searchResults = document.getElementById('search-results');
  const resultsGrid = document.getElementById('search-results-grid');
  const noResults = document.getElementById('no-results');
  let activeFilter = 'all';

  function renderSearchResults(products) {
    resultsGrid.innerHTML = '';
    if (!products.length) { noResults.style.display='block'; return; }
    noResults.style.display = 'none';
    // Show count
    let countEl = document.getElementById('search-result-count');
    if (!countEl) {
      countEl = document.createElement('p');
      countEl.id = 'search-result-count';
      countEl.className = 'search-result-count';
      searchResults.insertBefore(countEl, searchResults.firstChild);
    }
    const lang = window.YSP_LANG ? window.YSP_LANG.get() : 'en';
    const foundKey = products.length === 1 ? 'result_singular' : 'results_found';
    const foundText = window.YSP_LANG ? window.YSP_LANG.t(foundKey, lang) : (products.length === 1 ? 'product found' : 'products found');
    countEl.textContent = products.length + ' ' + foundText;
    products.forEach(p => {
      const a = document.createElement('a');
      a.className = 'search-product-card';
      a.href = '/products/' + p.slug + '.html';
      const badge = p.custom_badge || p.badge || '';
      a.innerHTML = `
        <div class="search-card-img">
          <img src="${p.image_main}" alt="${p.name}" loading="lazy">
        </div>
        ${badge ? `<div style="font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--accent-light);margin-bottom:0.3rem">${badge}</div>` : ''}
        <div class="search-card-name">${p.name}</div>
        <div class="search-card-meta">${p.brand}</div>
        <div class="search-card-price">€${p.price}</div>
      `;
      resultsGrid.appendChild(a);
    });
  }

  function runSearch() {
    const query = searchInput.value.toLowerCase().trim();
    searchResults.classList.add('visible');
    let filtered = ALL_PRODUCTS;
    if (activeFilter !== 'all') {
      if (activeFilter === 'fragrance') filtered = filtered.filter(p => p.type === 'fragrance');
      else if (activeFilter === 'beauty') filtered = filtered.filter(p => p.type === 'beauty');
      else filtered = filtered.filter(p => (p.accords || []).includes(activeFilter) || (p.category || '').toLowerCase().includes(activeFilter));
    }
    if (query) {
      filtered = filtered.filter(p => {
        const searchable = [p.name, p.brand, p.description_short, ...(p.accords||[]), p.fragrance_family, p.category].filter(Boolean).join(' ').toLowerCase();
        return searchable.includes(query);
      });
    }
    renderSearchResults(filtered);
  }

  searchInput.addEventListener('input', runSearch);

  document.querySelectorAll('.filter-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      activeFilter = chip.dataset.filter;
      searchResults.classList.add('visible');
      runSearch();
    });
  });
</script>
